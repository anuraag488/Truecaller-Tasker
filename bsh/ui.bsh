            matchDisplay.setCompoundDrawablePadding(u.dpToPx(8));
        }
        matchDisplay.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                builder = new android.app.AlertDialog.Builder(activity);
                views = new TextView[matches.size()];
                container = new LinearLayout(activity);
                container.setOrientation(LinearLayout.VERTICAL);
                container.setBackgroundColor(getColorInt("surface"));
                dialogRef = new Object[1];
                for (int i = 0; i < matches.size(); i++) {
                    tv = new TextView(activity);
                    tv.setText((String) matches.get(i));
                    tv.setPadding(u.dpToPx(16), u.dpToPx(16), u.dpToPx(16), u.dpToPx(16));
                    tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 14);
                    tv.setTextColor(getColorInt("on-surface"));
                    tv.setBackgroundColor(getColorInt("surface"));
                    views[i] = tv;
                    container.addView(tv);
                    capturedText = (String) matches.get(i);
                    tv.setOnClickListener(new View.OnClickListener() {
                        onClick(View v2) {
                            matchDisplay.setText(capturedText);
                            ((android.app.AlertDialog)dialogRef[0]).dismiss();
                        }
                    });
                }
                builder.setView(container);
                dAlert = builder.create();
                dialogRef[0] = dAlert;
                dAlert.getWindow().setBackgroundDrawable(new android.graphics.drawable.ColorDrawable(getColorInt("surface")));
                dAlert.show();
            }
        });
        matchSpinnerParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        matchSpinnerParams.topMargin = u.dpToPx(8);
        matchSpinnerParams.bottomMargin = u.dpToPx(16);
        matchDisplay.setLayoutParams(matchSpinnerParams);
        formLayout.addView(matchDisplay);

        valueLabel = new TextView(activity);
        valueLabel.setText("Value:");
        valueLabel.setTextSize(TypedValue.COMPLEX_UNIT_SP, 16);
        valueLabel.setTypeface(null, Typeface.BOLD);
        valueLabel.setTextColor(getColorInt("on-background"));
        formLayout.addView(valueLabel);
        
        filterNumber = (String) state.get("filterNumber");
        if (value != null) {
            cleanValue = value.replace("*", "");
            valueInput.setText(cleanValue);
        } else if (filterNumber != null && !filterNumber.isEmpty()) {
            valueInput.setText(filterNumber);
        }
        valueInputParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        valueInputParams.topMargin = u.dpToPx(8);
        valueInputParams.bottomMargin = u.dpToPx(16);
        valueInput.setLayoutParams(valueInputParams);
        formLayout.addView(valueInput);

        noteLabel = new TextView(activity);
        noteLabel.setText("Note (optional):");
        noteLabel.setTextSize(TypedValue.COMPLEX_UNIT_SP, 16);
        noteLabel.setTypeface(null, Typeface.BOLD);
        noteLabel.setTextColor(getColorInt("on-background"));
        formLayout.addView(noteLabel);
        
        noteInput = createStyledInput(activity, "Add note...");
        filterName = (String) state.get("filterName");
        if (note != null && !note.isEmpty()) {
            noteInput.setText(note);
        } else if (filterName != null && !filterName.isEmpty()) {
            noteInput.setText(filterName);
        }
        noteInputParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        noteInputParams.topMargin = u.dpToPx(8);
        noteInput.setLayoutParams(noteInputParams);
        formLayout.addView(noteInput);
        
        formScroll.addView(formLayout);
        rootLayout.addView(formScroll);

        buttonLayout = new LinearLayout(activity);
        buttonLayout.setOrientation(LinearLayout.HORIZONTAL);
        buttonLayout.setGravity(Gravity.CENTER);
        buttonLayout.setPadding(u.dpToPx(16), u.dpToPx(8), u.dpToPx(16), u.dpToPx(16));
        
        cancelButton = createStyledButton(activity, "Cancel", "mw_navigation_cancel", "surface-variant", "on-surface-variant");
        cancelButtonParams = new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0f);
        cancelButtonParams.rightMargin = u.dpToPx(12);
        cancelButton.setLayoutParams(cancelButtonParams);
        cancelButton.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                renderUserFiltersList(activity, rootLayout, dialog, state);
            }
        });
        buttonLayout.addView(cancelButton);
        
        saveButton = createStyledButton(activity, oldValue == null ? "Save" : "Update", "mw_content_save", "primary", "on-primary");
        saveButton.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0f));
        finalOldValue = oldValue;
        saveButton.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                selectedType = typeDisplay.getText().toString();
                selectedField = fieldDisplay.getText().toString();
                selectedMatch = matchDisplay.getText().toString();
                enteredValue = valueInput.getText().toString().trim();
                enteredNote = noteInput.getText().toString().trim();
                
                if (enteredValue.isEmpty()) {
                    tasker.showToast("Value cannot be empty");
                    return;
                }
                
                formattedValue = enteredValue;
                if (selectedMatch.equals("contains")) formattedValue = "*" + enteredValue + "*";
                else if (selectedMatch.equals("starts with")) formattedValue = enteredValue + "*";
                else if (selectedMatch.equals("ends with")) formattedValue = "*" + enteredValue;
                
                if (selectedField.equals("number") && !enteredValue.contains("*")) {
                    formattedValue = u.convertToE164(enteredValue);
                }
                
                if (finalOldValue != null) d.deleteFilter(finalOldValue);
                
                d.saveFilter(selectedType, selectedField, formattedValue, enteredNote);
                tasker.showToast("Filter " + (finalOldValue == null ? "added" : "updated"));
                renderUserFiltersList(activity, rootLayout, dialog, state);
            }
        });
        buttonLayout.addView(saveButton);
        rootLayout.addView(buttonLayout);
    }

    renderUserFiltersList(activity, rootLayout, dialog, state) {
        rootLayout.removeAllViews();
        state.put("currentView", "list");

        headerLayout = new LinearLayout(activity);
        headerLayout.setOrientation(LinearLayout.HORIZONTAL);
        headerLayout.setBackgroundColor(getColorInt("primary"));
        headerLayout.setPadding(u.dpToPx(4), u.dpToPx(4), u.dpToPx(4), u.dpToPx(4));
        headerLayout.setGravity(Gravity.CENTER_VERTICAL);
        
        backButton = createIconButton(activity, "mw_navigation_arrow_back", getThemeColor("on-primary"));
        backButtonParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        backButtonParams.rightMargin = u.dpToPx(8);
        backButton.setLayoutParams(backButtonParams);
        backButton.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                dialog.dismiss();
            }
        });
        headerLayout.addView(backButton);
        
        titleText = new TextView(activity);
        titleText.setText("User Filters");
        titleText.setTextSize(TypedValue.COMPLEX_UNIT_SP, 20);
        titleText.setTypeface(null, Typeface.BOLD);
        titleText.setTextColor(getColorInt("on-primary"));
        titleText.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0f));
        headerLayout.addView(titleText);
        rootLayout.addView(headerLayout);

        searchInput = createStyledInput(activity, "Search User Filters...");
        searchInputParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        searchInputParams.setMargins(u.dpToPx(16), u.dpToPx(16), u.dpToPx(16), u.dpToPx(12));
        searchInput.setLayoutParams(searchInputParams);
        rootLayout.addView(searchInput);

        filtersListContainer = new LinearLayout(activity);
        filtersListContainer.setOrientation(LinearLayout.VERTICAL);
        listBg = new GradientDrawable();
        listBg.setColor(getColorInt("surface"));
        listBg.setCornerRadius(u.dpToPx(16));
        listBg.setStroke(u.dpToPx(1), getColorInt("outline"));
        filtersListContainer.setBackground(listBg);
        containerParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, 0, 1.0f);
        containerParams.setMargins(u.dpToPx(16), 0, u.dpToPx(16), u.dpToPx(12));
        filtersListContainer.setLayoutParams(containerParams);
        filtersListContainer.setPadding(u.dpToPx(8), u.dpToPx(8), u.dpToPx(8), u.dpToPx(8));
        
        filtersScroll = new android.widget.ScrollView(activity);
        filtersScroll.setLayoutParams(new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.MATCH_PARENT));
        
        filtersContainer = new LinearLayout(activity);
        filtersContainer.setOrientation(LinearLayout.VERTICAL);
        
        refreshFiltersList = new Runnable() {
            run() {
                searchQuery = searchInput.getText().toString().toLowerCase().trim();
                filtersContainer.removeAllViews();
                filtersList = d.loadFilters();

                if (filtersList.isEmpty()) {
                    emptyText = new TextView(activity);
                    emptyText.setText("No filters found. Click \"+\" to add a new filter.");
                    emptyText.setTextSize(TypedValue.COMPLEX_UNIT_SP, 14);
                    emptyText.setTextColor(getColorInt("on-surface-variant"));
                    emptyText.setGravity(Gravity.CENTER);
                    emptyText.setPadding(u.dpToPx(20), u.dpToPx(32), u.dpToPx(20), u.dpToPx(32));
                    emptyTextParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
                    emptyText.setLayoutParams(emptyTextParams);
                    filtersContainer.addView(emptyText);
                    return;
                }

                matchCount = 0;
                for (int i = 0; i < filtersList.size(); i++) {
                    filter = (Object[]) filtersList.get(i);
                    filterType = (String) filter[0];
                    filterField = (String) filter[1];
                    filterValue = (String) filter[2];
                    filterEnabled = ((Boolean) filter[3]).booleanValue();
                    filterNote = (String) filter[4];
                    
                    if (searchQuery.isEmpty()) {
                        card = createFilterCard(activity, rootLayout, dialog, state, filterType, filterField, filterValue, filterEnabled, filterNote, this);
                        filtersContainer.addView(card);
                        matchCount++;
                    } else {
                        cleanValue = filterValue.replace("*", "").toLowerCase();
                        matchType = getMatchType(filterValue);
                        filterMatches = false;
                        if (matchType.equals("matches")) filterMatches = searchQuery.equals(cleanValue);
                        else if (matchType.equals("contains")) filterMatches = searchQuery.contains(cleanValue);
                        else if (matchType.equals("starts with")) filterMatches = searchQuery.startsWith(cleanValue);
                        else if (matchType.equals("ends with")) filterMatches = searchQuery.endsWith(cleanValue);
                        
                        if (filterMatches) {
                            card = createFilterCard(activity, rootLayout, dialog, state, filterType, filterField, filterValue, filterEnabled, filterNote, this);
                            filtersContainer.addView(card);
                            matchCount++;
                        }
                    }
                }

                if (matchCount == 0 && !searchQuery.isEmpty()) {
                    noResultsText = new TextView(activity);
                    noResultsText.setText("No filters match \"" + searchQuery + "\"");
                    noResultsText.setTextSize(TypedValue.COMPLEX_UNIT_SP, 14);
                    noResultsText.setTextColor(getColorInt("on-surface-variant"));
                    noResultsText.setGravity(Gravity.CENTER);
                    noResultsText.setPadding(u.dpToPx(20), u.dpToPx(32), u.dpToPx(20), u.dpToPx(32));
                    noResultsParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
                    noResultsText.setLayoutParams(noResultsParams);
                    filtersContainer.addView(noResultsText);
                }
            }
        };

        searchInput.addTextChangedListener(new android.text.TextWatcher() {
            beforeTextChanged(CharSequence s, int start, int count, int after) {}
            onTextChanged(CharSequence s, int start, int before, int count) {}
            afterTextChanged(android.text.Editable s) {
                refreshFiltersList.run();
            }
        });

        refreshFiltersList.run();
        filtersScroll.addView(filtersContainer);
        filtersListContainer.addView(filtersScroll);
        rootLayout.addView(filtersListContainer);

        buttonLayout = new LinearLayout(activity);
        buttonLayout.setOrientation(LinearLayout.HORIZONTAL);
        buttonLayout.setGravity(Gravity.CENTER);
        buttonLayout.setPadding(u.dpToPx(16), u.dpToPx(8), u.dpToPx(16), u.dpToPx(16));
        
        addButton = createStyledButton(activity, "Add", "mw_content_add", "primary", "on-primary");
        addButtonParams = new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0f);
        addButtonParams.rightMargin = u.dpToPx(12);
        addButton.setLayoutParams(addButtonParams);
        addButton.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                state.put("filterNumber", "");
                state.put("filterName", "");
                state.put("details", null);
                renderUserFiltersEdit(activity, rootLayout, dialog, state, "Block", null, null, null, null);
            }
        });
        buttonLayout.addView(addButton);
        
        pickButton = createStyledButton(activity, "Pick", "mw_action_touch_app", "primary", "on-primary");
        pickButton.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0f));
        pickButton.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                showPickDialog(activity, rootLayout, dialog, state);
            }
        });
        buttonLayout.addView(pickButton);
        rootLayout.addView(buttonLayout);
    }

    showUserFiltersDialog(activity, filterType, filterNumber, filterName, details) {
        if (filterNumber == null) filterNumber = "";
        if (filterName == null) filterName = "";
        
        if (filterType != null && !filterType.trim().isEmpty()) {
            filterTypeLower = filterType.toLowerCase().trim();
            if (filterTypeLower.equals("block")) filterType = "Block";
            else if (filterTypeLower.equals("allow") || filterTypeLower.equals("unblock")) filterType = "Allow";
            else filterType = "Block";
        } else {
            filterType = "Block";
        }

        dialog = new android.app.Dialog(activity, android.R.style.Theme_DeviceDefault_NoActionBar);
        dialog.getWindow().setBackgroundDrawable(new android.graphics.drawable.ColorDrawable(getColorInt("background")));
        dialog.getWindow().setLayout(android.view.WindowManager.LayoutParams.MATCH_PARENT, android.view.WindowManager.LayoutParams.MATCH_PARENT);
        
        rootLayout = new LinearLayout(activity);
        rootLayout.setOrientation(LinearLayout.VERTICAL);
        rootLayout.setBackgroundColor(getColorInt("background"));
        rootLayout.setFocusableInTouchMode(true);
        rootLayout.requestFocus();
        
        /* Apply window insets to prevent system bar overlapping */
        rootLayout.setOnApplyWindowInsetsListener(new android.view.View.OnApplyWindowInsetsListener() {
            onApplyWindowInsets(v, insets) {
                v.setPadding(
                    insets.getSystemWindowInsetLeft(),
                    insets.getSystemWindowInsetTop(),
                    insets.getSystemWindowInsetRight(),
                    insets.getSystemWindowInsetBottom()
                );
                return insets;
            }
        });
        
        state = new HashMap();
        state.put("filterType", filterType);
        state.put("filterNumber", filterNumber);
        state.put("filterName", filterName);
        state.put("details", details);
        state.put("currentView", "list");
        
        rootLayout.setOnKeyListener(new View.OnKeyListener() {
            onKey(View v, int keyCode, android.view.KeyEvent event) {
                if (keyCode == android.view.KeyEvent.KEYCODE_BACK && event.getAction() == android.view.KeyEvent.ACTION_UP) {
                    if (state.get("currentView").equals("edit")) {
                        renderUserFiltersList(activity, rootLayout, dialog, state);
                        return true;
                    } else {
                        dialog.dismiss();
                        return true;
                    }
                }
                return false;
            }
        });

        if (!filterNumber.isEmpty() || !filterName.isEmpty() || details != null) {
            renderUserFiltersEdit(activity, rootLayout, dialog, state, filterType, null, null, null, null);
        } else {
            renderUserFiltersList(activity, rootLayout, dialog, state);
        }

        dialog.setContentView(rootLayout);
        dialog.show();
        return dialog;
    }

    cleanup() {
        mainHandler.removeCallbacksAndMessages(null);
        if (executorService != null) executorService.shutdownNow();
        if (disposableMap != null) {
            valuesArray = disposableMap.values().toArray();
            for (int i = 0; i < valuesArray.length; i++) {
                try { valuesArray[i].dispose(); } catch (Exception e) {}
            }
            disposableMap.clear();
        }
        if (imageLoader != null) {
            imageLoader.shutdown();
        }
    }
    
    wrapBadges(ctx, badgesContainer, badgeList) {
        badgesContainer.removeAllViews();
        badgesContainer.setOrientation(LinearLayout.VERTICAL);
        badgesContainer.setGravity(Gravity.CENTER_HORIZONTAL);
        currentRow = new LinearLayout(ctx);
        currentRow.setOrientation(LinearLayout.HORIZONTAL);
        currentRow.setGravity(Gravity.CENTER_HORIZONTAL);
        rowParams = new LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        );
        rowParams.bottomMargin = u.dpToPx(8);
        currentRow.setLayoutParams(rowParams);
        badgesContainer.addView(currentRow);
        
        maxWidth = ctx.getResources().getDisplayMetrics().widthPixels * 0.8;
        currentWidth = 0;
        badgeMargin = u.dpToPx(6);
        
        for (int i = 0; i < badgeList.size(); i++) {
            badge = badgeList.get(i);
            badge.measure(0, 0);
            badgeWidth = badge.getMeasuredWidth() + badgeMargin;
            if (currentWidth + badgeWidth > maxWidth) {
                currentRow = new LinearLayout(ctx);
                currentRow.setOrientation(LinearLayout.HORIZONTAL);
                currentRow.setGravity(Gravity.CENTER_HORIZONTAL);
                rowParams2 = new LinearLayout.LayoutParams(
                    LinearLayout.LayoutParams.MATCH_PARENT,
                    LinearLayout.LayoutParams.WRAP_CONTENT
                );
                rowParams2.bottomMargin = u.dpToPx(8);
                currentRow.setLayoutParams(rowParams2);
                badgesContainer.addView(currentRow);
                currentWidth = 0;
            }
            params = new LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.WRAP_CONTENT,
                LinearLayout.LayoutParams.WRAP_CONTENT
            );
            params.rightMargin = badgeMargin;
            currentRow.addView(badge, params);
            currentWidth += badgeWidth;
        }
    }

    createBadge(ctx, text, iconName, bgColor, fgColor) {
        badge = new LinearLayout(ctx);
        badge.setOrientation(LinearLayout.HORIZONTAL);
        badge.setGravity(Gravity.CENTER_VERTICAL);
        badge.setPadding(u.dpToPx(8), u.dpToPx(6), u.dpToPx(8), u.dpToPx(6));
        bg = createCardBackground(bgColor, 12);
        badge.setBackground(bg);
        badgeParams = new LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        );
        badgeParams.rightMargin = u.dpToPx(6);
        badgeParams.topMargin = u.dpToPx(4);
        badge.setLayoutParams(badgeParams);
        
        if (u.isValidString(iconName)) {
            icon = new ImageView(ctx);
            iconSize = u.dpToPx(16);
            iconParams = new LinearLayout.LayoutParams(iconSize, iconSize);
            iconParams.rightMargin = u.dpToPx(4);
            icon.setLayoutParams(iconParams);
            icon.setColorFilter(Color.parseColor(fgColor));
            if (iconName.startsWith("http://") || iconName.startsWith("https://")) {
                loadIconAsync(iconName, icon);
            } else {
                drawable = getDrawable(ctx, iconName);
                if (drawable != null) icon.setImageDrawable(drawable);
            }
            badge.addView(icon);
        }
        if (u.isValidString(text)) {
            textView = new TextView(ctx);
            textView.setText(text);
            textView.setTextColor(Color.parseColor(fgColor));
            textView.setTextSize(TypedValue.COMPLEX_UNIT_SP, 12);
            textView.setTypeface(null, Typeface.BOLD);
            badge.addView(textView);
        }
        return badge;
    }

    createBadgesContainer(ctx, isVerified, spamScore, dataObj, warningMap) {
        badgeList = new java.util.ArrayList();
        
        if (isVerified) {
            badgeList.add(createBadge(ctx, "Verified", "mw_action_verified_user", getThemeColor("tertiary-container"), getThemeColor("on-tertiary-container")));
        }
        if (spamScore > 0) {
            spamText = spamScore + (spamScore == 1 ? " report" : " reports");
            badgeList.add(createBadge(ctx, spamText, "mw_action_report_problem", "#FFEBEE", "#D32F2F"));
        }
        if (dataObj != null) {
            try {
                if (dataObj.has("spamInfo")) {
                    spamInfo = dataObj.getJSONObject("spamInfo");
                    if (spamInfo.has("spamType")) {
                        spamType = spamInfo.getString("spamType");
                        if (u.isValidString(spamType)) {
                            badgeList.add(createBadge(ctx, spamType.replace("_", " "), "mw_action_report_problem", "#FFEBEE", "#D32F2F"));
                        }
                    }
                    if (spamInfo.has("spamCategories")) {
                        spamCategories = spamInfo.getJSONArray("spamCategories");
                        for (int i = 0; i < spamCategories.length(); i++) {
                            categoryId = spamCategories.getInt(i);
                            categoryDetails = d.getSpamCategoryDetails(categoryId);
                            if (categoryDetails != null) {
                                badgeList.add(createBadge(ctx, categoryDetails[0], categoryDetails[1], "#FFEBEE", "#D32F2F"));
                            }
                        }
                    }
                }
                if (dataObj.has("tags")) {
                    tagsArray = dataObj.getJSONArray("tags");
                    for (int i = 0; i < tagsArray.length(); i++) {
                        tagId = tagsArray.getString(i);
                        tagDetails = d.getTagDetails(tagId);
                        if (tagDetails != null) {
                            badgeList.add(createBadge(ctx, tagDetails[0], tagDetails[1], "#E8F5E9", "#2E7D32"));
                        }
                    }
                }
                if (dataObj.has("searchWarnings")) {
                    warnings = dataObj.getJSONArray("searchWarnings");
                    for (int i = 0; i < warnings.length(); i++) {
                        warning = warnings.getJSONObject(i);
                        warningId = warning.getString("id");
                        warningInfo = (Object[]) warningMap.get(warningId);
                        if (warningInfo != null) {
                            header = (String) warningInfo[0];
                            message = (String) warningInfo[1];
                            bgColor = (String) warningInfo[2];
                            fgColor = (String) warningInfo[3];
                            icon = (String) warningInfo[4];
                            if (warning.has("features")) {
                                features = warning.getJSONArray("features");
                                if (features.length() > 0) {
                                    feature = features.getJSONObject(0);
                                    if (feature.has("value")) {
                                        message = feature.getString("value");
                                    }
                                }
                            }
                            if (!u.isValidString(bgColor)) bgColor = "#000000";
                            if (!u.isValidString(fgColor)) fgColor = "#FFFFFF";
                            badgeList.add(createBadge(ctx, u.isValidString(message) ? header + ": " + message : header, icon, bgColor, fgColor));
                        }
                    }
                }
            } catch(Exception e) {
                u.logToFile("Error parsing badges: " + e.getMessage());
            }
        }
        
        if (badgeList.size() == 0) return null;
        
        badgesContainer = new LinearLayout(ctx);
        badgesContainer.setOrientation(LinearLayout.HORIZONTAL);
        badgesContainer.setLayoutParams(new LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, 
            LinearLayout.LayoutParams.WRAP_CONTENT
        ));
        badgesContainer.setGravity(Gravity.CENTER_HORIZONTAL);
        badgesContainerParams = badgesContainer.getLayoutParams();
        badgesContainerParams.topMargin = u.dpToPx(4);
        badgesContainerParams.bottomMargin = u.dpToPx(12);
        
        wrapBadges(ctx, badgesContainer, badgeList);
        return badgesContainer;
    }

    createStyledButton(ctx, text, iconName, bgColorKey, textColorKey) {
        btn = new Button(ctx);
        btn.setText(text);
        btn.setTextColor(getColorInt(textColorKey));
        btn.setTextSize(TypedValue.COMPLEX_UNIT_SP, 12);
        btn.setTypeface(null, Typeface.BOLD);
        btn.setAllCaps(false);
        btn.setGravity(Gravity.CENTER);
        drawable = getDrawable(ctx, iconName);
        if (drawable != null) {
            drawable.setTint(getColorInt(textColorKey));
            btn.setCompoundDrawablesWithIntrinsicBounds(null, drawable, null, null);
            btn.setCompoundDrawablePadding(u.dpToPx(4));
        }
        bg = new GradientDrawable();
        bg.setColor(getColorInt(bgColorKey));
        bg.setCornerRadius(u.dpToPx(8));
        btn.setBackground(bg);
        btn.setPadding(u.dpToPx(4), u.dpToPx(4), u.dpToPx(4), u.dpToPx(4));
        return btn;
    }

    createInfoCard(ctx, title, content, iconName, bgColorHex, textColorHex) {
        card = new LinearLayout(ctx);
        card.setOrientation(LinearLayout.HORIZONTAL);
        card.setPadding(u.dpToPx(12), u.dpToPx(12), u.dpToPx(12), u.dpToPx(12));
        cardParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        cardParams.topMargin = u.dpToPx(8);
        card.setLayoutParams(cardParams);
        cardBg = createCardBackground(bgColorHex, 8);
        card.setBackground(cardBg);
        
        if (u.isValidString(iconName)) {
            icon = new ImageView(ctx);
            iconSize = u.dpToPx(20);
            iconParams = new LinearLayout.LayoutParams(iconSize, iconSize);
            iconParams.rightMargin = u.dpToPx(8);
            icon.setLayoutParams(iconParams);
            if (iconName.startsWith("http://") || iconName.startsWith("https://")) {
                loadIconAsync(iconName, icon);
            } else {
                drawable = getDrawable(ctx, iconName);
                if (drawable != null) {
                    icon.setImageDrawable(drawable);
                    icon.setColorFilter(Color.parseColor(textColorHex));
                }
            }
            card.addView(icon);
        }
        
        contentColumn = new LinearLayout(ctx);
        contentColumn.setOrientation(LinearLayout.VERTICAL);
        contentColumn.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0f));
        titleText = new TextView(ctx);
        titleText.setText(title);
        titleText.setTextSize(TypedValue.COMPLEX_UNIT_SP, 14);
        titleText.setTypeface(null, Typeface.BOLD);
        titleText.setTextColor(Color.parseColor(textColorHex));
        contentColumn.addView(titleText);
        
        contentText = new TextView(ctx);
        contentText.setText(content);
        contentText.setTextSize(TypedValue.COMPLEX_UNIT_SP, 14);
        contentText.setTextColor(Color.parseColor(textColorHex));
        contentTextParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        contentTextParams.topMargin = u.dpToPx(4);
        contentText.setLayoutParams(contentTextParams);
        contentColumn.addView(contentText);
        
        card.addView(contentColumn);
        return card;
    }
    
    reloadColors() {
        themeColors.clear();
        colorCache.clear();
        tcTheme = tasker.getVariable("TC_theme");
        if (tcTheme == null || tcTheme.isEmpty()) {
            tcTheme = "Auto Dark Light";
        }
        
        themeObj = generateTheme(tcTheme);
        if (themeObj != null) {
            try {
                keys = themeObj.keys();
                while (keys.hasNext()) {
                    key = (String) keys.next();
                    themeColors.put(key, themeObj.getString(key));
                }
            } catch (Exception e) {
                u.logToFile("Error parsing generated theme: " + e.getMessage());
            }
        }
    }

    isNightMode() {
        configuration = context.getResources().getConfiguration();
        return (configuration.uiMode & 48) == 32; // UI_MODE_NIGHT_YES
    }

    getSystemColor(colorName) {
        resId = context.getResources().getIdentifier(colorName, "color", "android");
        if (resId != 0) {
            color = context.getResources().getColor(resId);
            return String.format("#%06X", new Object[]{new Integer(0xFFFFFF & color)});
        }
        return null;
    }

    extractMaterialYouColors() {
        sdkStr = tasker.getVariable("SDK");
        sdk = sdkStr != null ? Integer.parseInt(sdkStr) : 30;
        if (sdk < 31) return null;
        
        palette = new org.json.JSONObject();
        isDark = isNightMode();
        try {
            if (isDark) {
                palette.put("primary", getSystemColor("system_accent1_200"));
                palette.put("on-primary", getSystemColor("system_accent1_800"));
                palette.put("primary-container", getSystemColor("system_accent1_700"));
                palette.put("on-primary-container", getSystemColor("system_accent1_100"));
                palette.put("secondary", getSystemColor("system_accent2_200"));
                palette.put("on-secondary", getSystemColor("system_accent2_800"));
                palette.put("secondary-container", getSystemColor("system_accent2_700"));
                palette.put("on-secondary-container", getSystemColor("system_accent2_100"));
                palette.put("tertiary", getSystemColor("system_accent3_200"));
                palette.put("on-tertiary", getSystemColor("system_accent3_800"));
                palette.put("tertiary-container", getSystemColor("system_accent3_700"));
                palette.put("on-tertiary-container", getSystemColor("system_accent3_200"));
                palette.put("background", getSystemColor("system_neutral1_900"));
                palette.put("on-background", getSystemColor("system_neutral1_100"));
                palette.put("surface", getSystemColor("system_neutral1_900"));
                palette.put("on-surface", getSystemColor("system_neutral1_100"));
                palette.put("surface-variant", getSystemColor("system_neutral2_700"));
                palette.put("on-surface-variant", getSystemColor("system_neutral2_200"));
                palette.put("outline", getSystemColor("system_neutral2_500"));
                palette.put("outline-variant", getSystemColor("system_neutral2_800"));
            } else {
                palette.put("primary", getSystemColor("system_accent1_600"));
                palette.put("on-primary", getSystemColor("system_accent1_0"));
                palette.put("primary-container", getSystemColor("system_accent1_100"));
                palette.put("on-primary-container", getSystemColor("system_accent1_900"));
                palette.put("secondary", getSystemColor("system_accent2_600"));
                palette.put("on-secondary", getSystemColor("system_accent2_0"));
                palette.put("secondary-container", getSystemColor("system_accent2_100"));
                palette.put("on-secondary-container", getSystemColor("system_accent2_900"));
                palette.put("tertiary", getSystemColor("system_accent3_500"));
                palette.put("on-tertiary", getSystemColor("system_accent3_50"));
                palette.put("tertiary-container", getSystemColor("system_accent3_100"));
                palette.put("on-tertiary-container", getSystemColor("system_accent3_900"));
                palette.put("background", getSystemColor("system_neutral1_10"));
                palette.put("on-background", getSystemColor("system_neutral1_900"));
                palette.put("surface", getSystemColor("system_neutral1_10"));
                palette.put("on-surface", getSystemColor("system_neutral1_900"));
                palette.put("surface-variant", getSystemColor("system_neutral2_100"));
                palette.put("on-surface-variant", getSystemColor("system_neutral2_700"));
                palette.put("outline", getSystemColor("system_neutral2_500"));
                palette.put("outline-variant", getSystemColor("system_neutral2_300"));
            }
            palette.put("error", "#B00020");
            palette.put("on-error", "#FFFFFF");
            return palette;
        } catch (Exception e) { return null; }
    }

    hslToHex(hVal, sVal, lVal) {
        sNorm = sVal / 100.0f; lNorm = lVal / 100.0f;
        c = (1.0f - Math.abs(2.0f * lNorm - 1.0f)) * sNorm;
        x = c * (1.0f - Math.abs((hVal / 60.0f) % 2.0f - 1.0f));
        m = lNorm - c / 2.0f;
        rOut = 0.0f; gOut = 0.0f; bOut = 0.0f;
        if (hVal >= 0 && hVal < 60) { rOut = c; gOut = x; bOut = 0.0f; }
        else if (hVal >= 60 && hVal < 120) { rOut = x; gOut = c; bOut = 0.0f; }
        else if (hVal >= 120 && hVal < 180) { rOut = 0.0f; gOut = c; bOut = x; }
        else if (hVal >= 180 && hVal < 240) { rOut = 0.0f; gOut = x; bOut = c; }
        else if (hVal >= 240 && hVal < 300) { rOut = x; gOut = 0.0f; bOut = c; }
        else if (hVal >= 300 && hVal < 360) { rOut = c; gOut = 0.0f; bOut = x; }
        rFinal = Math.round((rOut + m) * 255.0f);
        gFinal = Math.round((gOut + m) * 255.0f);
        bFinal = Math.round((bOut + m) * 255.0f);
        return String.format("#%02X%02X%02X", new Object[]{new Integer(rFinal), new Integer(gFinal), new Integer(bFinal)});
    }

    generatePaletteFromColor(hexColor, isDark) {
        palette = new org.json.JSONObject();
        color = Color.parseColor(hexColor);
        r = Color.red(color) / 255.0f; g = Color.green(color) / 255.0f; b = Color.blue(color) / 255.0f;
        max = Math.max(Math.max(r, g), b); min = Math.min(Math.min(r, g), b);
        h = 0.0f; s = 0.0f; l = (max + min) / 2.0f;
        if (max != min) {
            d = max - min;
            s = l > 0.5f ? d / (2.0f - max - min) : d / (max + min);
            if (max == r) h = (g - b) / d + (g < b ? 6.0f : 0.0f);
            else if (max == g) h = (b - r) / d + 2.0f;
            else h = (r - g) / d + 4.0f;
            h /= 6.0f;
        }
        hue = Math.round(h * 360.0f); saturation = Math.round(s * 100.0f);
        secondaryHue = (hue + 30) % 360; tertiaryHue = (hue + 60) % 360;
        secondarySat = (int)(saturation * 0.4f); tertiarySat = (int)(saturation * 0.6f);
        
        if (isDark) {
            palette.put("primary", hslToHex(hue, saturation, 80));
            palette.put("on-primary", hslToHex(hue, saturation, 20));
            palette.put("primary-container", hslToHex(hue, saturation, 30));
            palette.put("on-primary-container", hslToHex(hue, saturation, 90));
            palette.put("secondary", hslToHex(secondaryHue, secondarySat, 80));
            palette.put("on-secondary", hslToHex(secondaryHue, secondarySat, 20));
            palette.put("secondary-container", hslToHex(secondaryHue, secondarySat, 30));
            palette.put("on-secondary-container", hslToHex(secondaryHue, secondarySat, 90));
            palette.put("tertiary", hslToHex(tertiaryHue, tertiarySat, 80));
            palette.put("on-tertiary", hslToHex(tertiaryHue, tertiarySat, 20));
            palette.put("tertiary-container", hslToHex(tertiaryHue, tertiarySat, 30));
            palette.put("on-tertiary-container", hslToHex(tertiaryHue, tertiarySat, 90));
            palette.put("background", hslToHex(hue, 5, 10));
            palette.put("on-background", hslToHex(hue, 5, 90));
            palette.put("surface", hslToHex(hue, 5, 10));
            palette.put("on-surface", hslToHex(hue, 5, 90));
            palette.put("surface-variant", hslToHex(hue, 5, 30));
            palette.put("on-surface-variant", hslToHex(hue, 5, 80));
            palette.put("outline", hslToHex(hue, 5, 60));
            palette.put("outline-variant", hslToHex(hue, 5, 30));
        } else {
            palette.put("primary", hslToHex(hue, saturation, 40));
            palette.put("on-primary", hslToHex(hue, saturation, 100));
            palette.put("primary-container", hslToHex(hue, saturation, 90));
            palette.put("on-primary-container", hslToHex(hue, saturation, 10));
            palette.put("secondary", hslToHex(secondaryHue, secondarySat, 40));
            palette.put("on-secondary", hslToHex(secondaryHue, secondarySat, 100));
            palette.put("secondary-container", hslToHex(secondaryHue, secondarySat, 90));
            palette.put("on-secondary-container", hslToHex(secondaryHue, secondarySat, 10));
            palette.put("tertiary", hslToHex(tertiaryHue, tertiarySat, 40));
            palette.put("on-tertiary", hslToHex(tertiaryHue, tertiarySat, 100));
            palette.put("tertiary-container", hslToHex(tertiaryHue, tertiarySat, 90));
            palette.put("on-tertiary-container", hslToHex(tertiaryHue, tertiarySat, 10));
            palette.put("background", hslToHex(hue, 5, 99));
            palette.put("on-background", hslToHex(hue, 5, 10));
            palette.put("surface", hslToHex(hue, 5, 99));
            palette.put("on-surface", hslToHex(hue, 5, 10));
            palette.put("surface-variant", hslToHex(hue, 5, 90));
            palette.put("on-surface-variant", hslToHex(hue, 5, 30));
            palette.put("outline", hslToHex(hue, 5, 50));
            palette.put("outline-variant", hslToHex(hue, 5, 80));
        }
        palette.put("error", "#B00020");
        palette.put("on-error", "#FFFFFF");
        return palette;
    }

    generateTheme(themeValue) {
        palette = new org.json.JSONObject();
        isDark = isNightMode();
        if (themeValue.equals("Material You")) {
            palette = extractMaterialYouColors();
            if (palette != null) return palette;
            themeValue = "Auto Dark Light";
        }
        if (themeValue.equals("Auto Dark Light")) themeValue = isDark ? "Dark" : "Light";
        
        if (themeValue.equals("Dark")) {
            palette.put("primary", "#FFFFFF"); palette.put("on-primary", "#000000");
            palette.put("primary-container", "#222222"); palette.put("on-primary-container", "#FFFFFF");
            palette.put("secondary", "#BBBBBB"); palette.put("on-secondary", "#000000");
            palette.put("secondary-container", "#444444"); palette.put("on-secondary-container", "#FFFFFF");
            palette.put("tertiary", "#888888"); palette.put("on-tertiary", "#000000");
            palette.put("tertiary-container", "#222222"); palette.put("on-tertiary-container", "#FFFFFF");
            palette.put("background", "#000000"); palette.put("on-background", "#FFFFFF");
            palette.put("surface", "#121212"); palette.put("on-surface", "#FFFFFF");
            palette.put("surface-variant", "#222222"); palette.put("on-surface-variant", "#DDDDDD");
            palette.put("outline", "#777777"); palette.put("outline-variant", "#444444");
            palette.put("error", "#B00020"); palette.put("on-error", "#FFFFFF");
        } else if (themeValue.equals("Light")) {
            palette.put("primary", "#000000"); palette.put("on-primary", "#FFFFFF");
            palette.put("primary-container", "#E0E0E0"); palette.put("on-primary-container", "#000000");
            palette.put("secondary", "#333333"); palette.put("on-secondary", "#FFFFFF");
            palette.put("secondary-container", "#F5F5F5"); palette.put("on-secondary-container", "#000000");
            palette.put("tertiary", "#666666"); palette.put("on-tertiary", "#FFFFFF");
            palette.put("tertiary-container", "#DDDDDD"); palette.put("on-tertiary-container", "#000000");
            palette.put("background", "#FFFFFF"); palette.put("on-background", "#000000");
            palette.put("surface", "#FFFFFF"); palette.put("on-surface", "#000000");
            palette.put("surface-variant", "#F0F0F0"); palette.put("on-surface-variant", "#333333");
            palette.put("outline", "#999999"); palette.put("outline-variant", "#CCCCCC");
            palette.put("error", "#B00020"); palette.put("on-error", "#FFFFFF");
        } else if (themeValue.startsWith("#")) {
            palette = generatePaletteFromColor(themeValue, isDark);
        }
        return palette;
    }

    createThemedCheckbox(activity, varName, defaultValue) {
        checkbox = new android.widget.CheckBox(activity);
        checkbox.setButtonDrawable(null);
        checkedDrawable = getDrawable(activity, "mw_toggle_check_box");
        uncheckedDrawable = getDrawable(activity, "mw_toggle_check_box_outline_blank");
        if (checkedDrawable != null) checkedDrawable.setTint(getColorInt("primary"));
        if (uncheckedDrawable != null) uncheckedDrawable.setTint(getColorInt("outline"));
        
        savedValue = tasker.getVariable(varName);
        if (savedValue == null) {
            checkbox.setChecked(defaultValue);
            tasker.setVariable(varName, defaultValue ? "true" : "false");
        } else {
            checkbox.setChecked(savedValue.equals("true"));
        }
        
        checkbox.setOnCheckedChangeListener(new android.widget.CompoundButton.OnCheckedChangeListener() {
            onCheckedChanged(android.widget.CompoundButton buttonView, boolean isChecked) {
                tasker.setVariable(varName, isChecked ? "true" : "false");
                taskVars = new java.util.HashMap();
                taskVars.put("par1", "enable");
                tasker.callTask("Truecaller - Helper", taskVars);
                drawable = isChecked ? checkedDrawable : uncheckedDrawable;
                if (drawable != null) buttonView.setButtonDrawable(drawable);
            }
        });
        
        initialDrawable = checkbox.isChecked() ? checkedDrawable : uncheckedDrawable;
        if (initialDrawable != null) checkbox.setButtonDrawable(initialDrawable);
        return checkbox;
    }

    createThemedSettingsButton(activity, text) {
        button = new android.widget.Button(activity);
        button.setText(text);
        button.setTextColor(getColorInt("on-primary"));
        bg = new GradientDrawable();
        bg.setColor(getColorInt("primary"));
        bg.setCornerRadius(u.dpToPx(10));
        button.setBackground(bg);
        button.setPadding(u.dpToPx(16), u.dpToPx(10), u.dpToPx(16), u.dpToPx(10));
        button.setAllCaps(false);
        return button;
    }

    createSettingItem(activity, label, control) {
        container = new LinearLayout(activity);
        container.setOrientation(LinearLayout.HORIZONTAL);
        container.setGravity(Gravity.CENTER_VERTICAL);
        container.setPadding(u.dpToPx(16), u.dpToPx(12), u.dpToPx(16), u.dpToPx(12));
        container.setBackground(createCardBackground(getThemeColor("surface"), 16));
        params = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        params.setMargins(u.dpToPx(8), u.dpToPx(8), u.dpToPx(8), u.dpToPx(8));
        container.setLayoutParams(params);
        
        labelView = new TextView(activity);
        labelView.setText(label);
        labelView.setTextColor(getColorInt("on-surface"));
        labelView.setTextSize(16);
        labelParams = new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0f);
        labelView.setLayoutParams(labelParams);
        
        container.addView(labelView);
        container.addView(control);
        
        if (control instanceof android.widget.CheckBox) {
            finalControl = (android.widget.CheckBox) control;
            container.setOnClickListener(new View.OnClickListener() {
                onClick(View v) { finalControl.setChecked(!finalControl.isChecked()); }
            });
        }
        return container;
    }

    createSettingItemWithDescription(activity, label, description, control) {
        container = new LinearLayout(activity);
        container.setOrientation(LinearLayout.HORIZONTAL);
        container.setGravity(Gravity.CENTER_VERTICAL);
        container.setPadding(u.dpToPx(16), u.dpToPx(12), u.dpToPx(16), u.dpToPx(12));
        container.setBackground(createCardBackground(getThemeColor("surface"), 16));
        params = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        params.setMargins(u.dpToPx(8), u.dpToPx(8), u.dpToPx(8), u.dpToPx(8));
        container.setLayoutParams(params);
        
        textContainer = new LinearLayout(activity);
        textContainer.setOrientation(LinearLayout.VERTICAL);
        textParams = new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0f);
        textContainer.setLayoutParams(textParams);
        
        labelView = new TextView(activity);
        labelView.setText(label);
        labelView.setTextColor(getColorInt("on-surface"));
        labelView.setTextSize(16);
        textContainer.addView(labelView);
        
        if (description != null && !description.isEmpty()) {
            descView = new TextView(activity);
            descView.setText(description);
            descView.setTextColor(getColorInt("on-surface-variant"));
            descView.setTextSize(12);
            descParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT);
            descParams.topMargin = u.dpToPx(4);
            descView.setLayoutParams(descParams);
            textContainer.addView(descView);
        }
        
        container.addView(textContainer);
        container.addView(control);
        if (control instanceof android.widget.CheckBox) {
            finalControl = (android.widget.CheckBox) control;
            container.setOnClickListener(new View.OnClickListener() {
                onClick(View v) { finalControl.setChecked(!finalControl.isChecked()); }
            });
        }
        return container;
    }

    showColorPickerDialog(activity, currentColor, parentDialog, onThemeChanged) {
        dialog = new android.app.Dialog(activity);
        dialog.requestWindowFeature(1);
        
        mainContainer = new LinearLayout(activity);
        mainContainer.setOrientation(LinearLayout.VERTICAL);
        mainContainer.setBackground(createCardBackground(getThemeColor("surface"), 16));
        mainContainer.setPadding(u.dpToPx(24), u.dpToPx(24), u.dpToPx(24), u.dpToPx(16));
        
        titleView = new TextView(activity);
        titleView.setText("Choose Custom Color");
        titleView.setTextSize(TypedValue.COMPLEX_UNIT_SP, 20);
        titleView.setTypeface(null, Typeface.BOLD);
        titleView.setTextColor(getColorInt("on-surface"));
        titleView.setPadding(0, 0, 0, u.dpToPx(16));
        mainContainer.addView(titleView);
        
        previewContainer = new LinearLayout(activity);
        previewContainer.setOrientation(LinearLayout.HORIZONTAL);
        previewContainer.setGravity(Gravity.CENTER_VERTICAL);
        previewContainer.setPadding(0, 0, 0, u.dpToPx(16));
        
        previewLabel = new TextView(activity);
        previewLabel.setText("Preview:");
        previewLabel.setTextSize(16);
        previewLabel.setTextColor(getColorInt("on-surface"));
        previewLabelParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        previewLabelParams.rightMargin = u.dpToPx(12);
        previewLabel.setLayoutParams(previewLabelParams);
        previewContainer.addView(previewLabel);
        
        previewBox = new View(activity);
        previewBoxParams = new LinearLayout.LayoutParams(u.dpToPx(60), u.dpToPx(60));
        previewBox.setLayoutParams(previewBoxParams);
        previewBoxBg = new GradientDrawable();
        previewBoxBg.setCornerRadius(u.dpToPx(8));
        previewBoxBg.setColor(currentColor != null && currentColor.startsWith("#") ? Color.parseColor(currentColor) : getColorInt("primary"));
        previewBox.setBackground(previewBoxBg);
        previewContainer.addView(previewBox);
        mainContainer.addView(previewContainer);
        
        hexInputLabel = new TextView(activity);
        hexInputLabel.setText("Hex Color Code:");
        hexInputLabel.setTextSize(14);
        hexInputLabel.setTextColor(getColorInt("on-surface"));
        hexInputLabel.setPadding(0, 0, 0, u.dpToPx(8));
        mainContainer.addView(hexInputLabel);
        
        hexInput = new android.widget.EditText(activity);
        hexInput.setHint("#FF5722");
        hexInput.setSingleLine(true);
        hexInput.setTextSize(16);
        hexInput.setTextColor(getColorInt("on-surface"));
        hexInput.setHintTextColor(getColorInt("on-surface-variant"));
        hexInputBg = new GradientDrawable();
        hexInputBg.setColor(getColorInt("surface-variant"));
        hexInputBg.setCornerRadius(u.dpToPx(8));
        hexInput.setBackground(hexInputBg);
        hexInput.setPadding(u.dpToPx(16), u.dpToPx(12), u.dpToPx(16), u.dpToPx(12));
        hexInputParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        hexInputParams.bottomMargin = u.dpToPx(16);
        hexInput.setLayoutParams(hexInputParams);
        
        if (currentColor != null && currentColor.startsWith("#")) hexInput.setText(currentColor);
        
        hexInput.addTextChangedListener(new android.text.TextWatcher() {
            beforeTextChanged(CharSequence s, int start, int count, int after) {}
            onTextChanged(CharSequence s, int start, int before, int count) {}
            afterTextChanged(android.text.Editable s) {
                colorText = s.toString().trim();
                if (!colorText.startsWith("#")) colorText = "#" + colorText;
                if (colorText.length() == 7 || colorText.length() == 9) {
                    try {
                        newColor = Color.parseColor(colorText);
                        updateBg = new GradientDrawable();
                        updateBg.setCornerRadius(u.dpToPx(8));
                        updateBg.setColor(newColor);
                        previewBox.setBackground(updateBg);
                    } catch (Exception e) {}
                }
            }
        });
        mainContainer.addView(hexInput);
        
        presetsLabel = new TextView(activity);
        presetsLabel.setText("Quick Presets:");
        presetsLabel.setTextSize(14);
        presetsLabel.setTextColor(getColorInt("on-surface"));
        presetsLabel.setPadding(0, 0, 0, u.dpToPx(12));
        mainContainer.addView(presetsLabel);
        
        presetColors = new String[]{
            "#F44336", "#E91E63", "#9C27B0", "#673AB7",
            "#3F51B5", "#2196F3", "#03A9F4", "#00BCD4",
            "#009688", "#4CAF50", "#8BC34A", "#CDDC39",
            "#FFEB3B", "#FFC107", "#FF9800", "#FF5722"
        };
        
        currentRow = null;
        for (int i = 0; i < presetColors.length; i++) {
            if (i % 4 == 0) {
                currentRow = new LinearLayout(activity);
                currentRow.setOrientation(LinearLayout.HORIZONTAL);
                currentRow.setGravity(Gravity.CENTER);
                rowParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
                rowParams.bottomMargin = u.dpToPx(8);
                currentRow.setLayoutParams(rowParams);
                mainContainer.addView(currentRow);
            }
            presetBtn = new View(activity);
            presetBtnParams = new LinearLayout.LayoutParams(u.dpToPx(48), u.dpToPx(48));
            presetBtnParams.setMargins(u.dpToPx(4), 0, u.dpToPx(4), 0);
            presetBtn.setLayoutParams(presetBtnParams);
            pBg = new GradientDrawable();
            pBg.setCornerRadius(u.dpToPx(8));
            pBg.setColor(Color.parseColor(presetColors[i]));
            presetBtn.setBackground(pBg);
            presetBtn.setTag(presetColors[i]);
            presetBtn.setOnClickListener(new View.OnClickListener() {
                onClick(View v) { hexInput.setText((String) v.getTag()); }
            });
            currentRow.addView(presetBtn);
        }
        
        buttonContainer = new LinearLayout(activity);
        buttonContainer.setOrientation(LinearLayout.HORIZONTAL);
        buttonContainer.setGravity(Gravity.END);
        buttonContainer.setPadding(0, u.dpToPx(16), 0, 0);
        
        cancelBtn = new android.widget.Button(activity);
        cancelBtn.setText("Cancel");
        cancelBtn.setTextColor(getColorInt("primary"));
        cancelBtn.setBackgroundColor(Color.TRANSPARENT);
        cancelBtn.setOnClickListener(new View.OnClickListener() {
            onClick(View v) { dialog.dismiss(); }
        });
        buttonContainer.addView(cancelBtn);
        
        applyBtn = new android.widget.Button(activity);
        applyBtn.setText("Apply");
        applyBtn.setTextColor(getColorInt("on-primary"));
        aBg = new GradientDrawable();
        aBg.setColor(getColorInt("primary"));
        aBg.setCornerRadius(u.dpToPx(8));
        applyBtn.setBackground(aBg);
        applyBtn.setPadding(u.dpToPx(16), u.dpToPx(8), u.dpToPx(16), u.dpToPx(8));
        applyBtnParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        applyBtnParams.leftMargin = u.dpToPx(8);
        applyBtn.setLayoutParams(applyBtnParams);
        
        applyBtn.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                colorText = hexInput.getText().toString().trim();
                if (!colorText.startsWith("#")) colorText = "#" + colorText;
                if (colorText.length() == 7 || colorText.length() == 9) {
                    try {
                        Color.parseColor(colorText);
                        tasker.setVariable("TC_theme", colorText);
                        reloadColors();
                        if (onThemeChanged != null) { onThemeChanged.run(); }
                        
                        if (parentDialog != null) {
                            parentDialog.setOnDismissListener(null);
                            parentDialog.dismiss();
                        }
                        dialog.dismiss();
                        
                        tasker.showToast("Theme updated");
                        showSettingsDialog(activity, onThemeChanged);
                    } catch (Exception e) { tasker.showToast("Invalid color code"); }
                } else {
                    tasker.showToast("Please enter valid hex color");
                }
            }
        });
        buttonContainer.addView(applyBtn);
        mainContainer.addView(buttonContainer);
        
        dialog.setContentView(mainContainer);
        if (dialog.getWindow() != null) {
            dialog.getWindow().setBackgroundDrawable(new android.graphics.drawable.ColorDrawable(Color.TRANSPARENT));
            dialog.getWindow().setLayout((int)(activity.getResources().getDisplayMetrics().widthPixels * 0.90), ViewGroup.LayoutParams.WRAP_CONTENT);
        }
        dialog.show();
    }

    createSettingPickerButton(activity, label, varName, options, defaultValue, parentDialog, onThemeChanged) {
        pickerButton = createThemedSettingsButton(activity, "");
        pickerButton.setLayoutParams(new LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT));
        savedValue = tasker.getVariable(varName);
        if (savedValue == null) {
            savedValue = defaultValue;
            tasker.setVariable(varName, defaultValue);
        }
        if (varName.equals("TC_theme") && savedValue.startsWith("#")) pickerButton.setText("Custom: " + savedValue);
        else pickerButton.setText(savedValue);

        pickerButton.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                final android.app.Dialog dialog = new android.app.Dialog(activity);
                dialog.requestWindowFeature(1);
                
                root = new LinearLayout(activity);
                root.setOrientation(LinearLayout.VERTICAL);
                root.setBackground(createCardBackground(getThemeColor("surface"), 16));
                
                titleView = new TextView(activity);
                titleView.setText(label);
                titleView.setTextSize(TypedValue.COMPLEX_UNIT_SP, 20);
                titleView.setTypeface(null, Typeface.BOLD);
                titleView.setTextColor(getColorInt("on-surface"));
                titleView.setPadding(u.dpToPx(24), u.dpToPx(24), u.dpToPx(24), u.dpToPx(12));
                root.addView(titleView);
                
                scrollHost = new android.widget.ScrollView(activity);
                listContainer = new LinearLayout(activity);
                listContainer.setOrientation(LinearLayout.VERTICAL);
                listContainer.setPadding(u.dpToPx(8), 0, u.dpToPx(8), 0);
                scrollHost.addView(listContainer);
                
                scrollParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, 0, 1.0f);
                root.addView(scrollHost, scrollParams);

                currentValue = tasker.getVariable(varName);
                for (int i = 0; i < options.length; i++) {
                    final String opt = options[i];
                    rb = new android.widget.RadioButton(activity);
                    rb.setText(opt);
                    rb.setTextSize(16);
                    rb.setTextColor(getColorInt("on-surface"));
                    rb.setPadding(u.dpToPx(16), u.dpToPx(12), u.dpToPx(16), u.dpToPx(12));
                    if (android.os.Build.VERSION.SDK_INT >= 21) {
                        rb.setButtonTintList(android.content.res.ColorStateList.valueOf(getColorInt("primary")));
                    }
                    if (opt.equals(currentValue)) rb.setChecked(true);
                    
                    rb.setOnClickListener(new View.OnClickListener() {
                        onClick(View v2) {
                            selectedValue = opt;
                            oldValue = tasker.getVariable(varName);
                            if (varName.equals("TC_theme") && selectedValue.equals("Custom Color")) {
                                dialog.dismiss();
                                currentTheme = tasker.getVariable("TC_theme");
                                currentColor = (currentTheme != null && currentTheme.startsWith("#")) ? currentTheme : null;
                                showColorPickerDialog(activity, currentColor, parentDialog, onThemeChanged);
                                return;
                            }
                            pickerButton.setText(selectedValue);
                            if (oldValue != null && !oldValue.equals(selectedValue)) {
                                tasker.setVariable(varName, selectedValue);
                                if (varName.equals("TC_theme")) {
                                    reloadColors();
                                    if (onThemeChanged != null) { onThemeChanged.run(); }
                                    
                                    if (parentDialog != null) {
                                        parentDialog.setOnDismissListener(null);
                                        parentDialog.dismiss();
                                    }
                                    dialog.dismiss();
                                    
                                    showSettingsDialog(activity, onThemeChanged);
                                    return;
                                }
                            } else if (oldValue == null) {
                                tasker.setVariable(varName, selectedValue);
                            }
                            dialog.dismiss();
                        }
                    });
                    listContainer.addView(rb);
                }

                footer = new LinearLayout(activity);
                footer.setOrientation(LinearLayout.HORIZONTAL);
                footer.setGravity(Gravity.END);
                footer.setPadding(u.dpToPx(8), u.dpToPx(8), u.dpToPx(24), u.dpToPx(16));
                
                cancelBtn = new android.widget.Button(activity);
                cancelBtn.setText("Cancel");
                cancelBtn.setTextColor(getColorInt("primary"));
                cancelBtn.setBackgroundColor(Color.TRANSPARENT);
                cancelBtn.setOnClickListener(new View.OnClickListener() {
                    onClick(View v3) { dialog.dismiss(); }
                });
                footer.addView(cancelBtn);
                root.addView(footer);

                dialog.setContentView(root);
                if (dialog.getWindow() != null) {
                    dialog.getWindow().setBackgroundDrawable(new android.graphics.drawable.ColorDrawable(Color.TRANSPARENT));
                    dialog.getWindow().setLayout((int)(activity.getResources().getDisplayMetrics().widthPixels * 0.90), ViewGroup.LayoutParams.WRAP_CONTENT);
                }
                dialog.show();
            }
        });
        return createSettingItem(activity, label, pickerButton);
    }

    showSettingsDialog(activity, onThemeChanged) {
        dialog = new android.app.Dialog(activity, android.R.style.Theme_DeviceDefault_NoActionBar);
        dialog.getWindow().setBackgroundDrawable(new android.graphics.drawable.ColorDrawable(getColorInt("background")));
        dialog.getWindow().setLayout(android.view.WindowManager.LayoutParams.MATCH_PARENT, android.view.WindowManager.LayoutParams.MATCH_PARENT);
        
        mainLayout = new LinearLayout(activity);
        mainLayout.setOrientation(LinearLayout.VERTICAL);
        mainLayout.setBackgroundColor(getColorInt("surface-variant"));
        mainLayout.setFocusableInTouchMode(true);
        mainLayout.requestFocus();
        mainLayout.setFitsSystemWindows(true);
        
        mainLayout.setOnApplyWindowInsetsListener(new android.view.View.OnApplyWindowInsetsListener() {
            onApplyWindowInsets(v, insets) {
                v.setPadding(
                    insets.getSystemWindowInsetLeft(),
                    insets.getSystemWindowInsetTop(),
                    insets.getSystemWindowInsetRight(),
                    insets.getSystemWindowInsetBottom()
                );
                return insets;
            }
        });

        // Header
        headerLayout = new LinearLayout(activity);
        headerLayout.setOrientation(LinearLayout.HORIZONTAL);
        headerLayout.setBackgroundColor(getColorInt("primary"));
        headerLayout.setPadding(u.dpToPx(4), u.dpToPx(4), u.dpToPx(4), u.dpToPx(4));
        headerLayout.setGravity(Gravity.CENTER_VERTICAL);
        
        backButton = createIconButton(activity, "mw_navigation_arrow_back", getThemeColor("on-primary"));
        backButtonParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        backButtonParams.rightMargin = u.dpToPx(8);
        backButton.setLayoutParams(backButtonParams);
        backButton.setOnClickListener(new View.OnClickListener() {
            onClick(View v) { dialog.dismiss(); }
        });
        headerLayout.addView(backButton);
        
        titleText = new TextView(activity);
        titleText.setText("Settings");
        titleText.setTextSize(TypedValue.COMPLEX_UNIT_SP, 20);
        titleText.setTypeface(null, Typeface.BOLD);
        titleText.setTextColor(getColorInt("on-primary"));
        titleText.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0f));
        headerLayout.addView(titleText);
        mainLayout.addView(headerLayout);

        // Tabs setup
        generalTab = new LinearLayout(activity);
        generalTab.setOrientation(LinearLayout.VERTICAL);
        callerIdTab = new LinearLayout(activity);
        callerIdTab.setOrientation(LinearLayout.VERTICAL);
        filterTab = new LinearLayout(activity);
        filterTab.setOrientation(LinearLayout.VERTICAL);

        generalTabScroll = new android.widget.ScrollView(activity);
        generalTabScroll.addView(generalTab);
        generalTabScroll.setLayoutParams(new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, 0, 1.0f));
        generalTabScroll.setVisibility(View.VISIBLE);

        callerIdTabScroll = new android.widget.ScrollView(activity);
        callerIdTabScroll.addView(callerIdTab);
        callerIdTabScroll.setLayoutParams(new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, 0, 1.0f));
        callerIdTabScroll.setVisibility(View.GONE);

        filterTabScroll = new android.widget.ScrollView(activity);
        filterTabScroll.addView(filterTab);
        filterTabScroll.setLayoutParams(new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, 0, 1.0f));
        filterTabScroll.setVisibility(View.GONE);

        setTabContainer = new LinearLayout(activity);
        setTabContainer.setOrientation(LinearLayout.VERTICAL);
        setTabContainer.setBackgroundColor(getColorInt("surface"));
        setTabContainer.setElevation(u.dpToPx(4));
