        metaLayout.addView(matchText);
        card.addView(metaLayout);
        
        valueLayout = new LinearLayout(activity);
        valueLayout.setOrientation(LinearLayout.VERTICAL);
        valueLayout.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0f));
        valueLayout.setGravity(Gravity.CENTER_HORIZONTAL);
        
        cleanValue = value.replace("*", "");
