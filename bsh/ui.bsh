        setTabIndicatorBg = new GradientDrawable();
        setTabIndicatorBg.setColor(getColorInt("primary"));
        setTabIndicatorBg.setCornerRadius(u.dpToPx(3));
        setTabIndicator.setBackground(setTabIndicatorBg);

        setIndicatorContainer = new LinearLayout(activity);
        setIndicatorContainer.setOrientation(LinearLayout.HORIZONTAL);
        setIndicatorContainerParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, u.dpToPx(3));
        setIndicatorContainer.setLayoutParams(setIndicatorContainerParams);
        setIndicatorContainer.setPadding(u.dpToPx(16), 0, u.dpToPx(16), 0);

        setSpacer1 = new View(activity);
        setSpacer1Params = new LinearLayout.LayoutParams(0, u.dpToPx(3));
        setSpacer1Params.weight = 1.0f;
        setSpacer1.setLayoutParams(setSpacer1Params);

        setSpacer2 = new View(activity);
        setSpacer2Params = new LinearLayout.LayoutParams(0, u.dpToPx(3));
        setSpacer2Params.weight = 1.0f;
        setSpacer2.setLayoutParams(setSpacer2Params);

        setIndicatorContainer.addView(setTabIndicator);
        setIndicatorContainer.addView(setSpacer1);
        setIndicatorContainer.addView(setSpacer2);

        setTabsWithIndicator.addView(setTabButtonLayout);
        setTabsWithIndicator.addView(setIndicatorContainer);
        setTabContainer.addView(setTabsWithIndicator);

        switchToTab(tabIndex) {
            generalTabScroll.setVisibility(tabIndex == 0 ? View.VISIBLE : View.GONE);
            callerIdTabScroll.setVisibility(tabIndex == 1 ? View.VISIBLE : View.GONE);
            filterTabScroll.setVisibility(tabIndex == 2 ? View.VISIBLE : View.GONE);
            
            setIndicatorContainer.removeAllViews();
            if (setTabIndicator.getParent() != null) ((android.view.ViewGroup)setTabIndicator.getParent()).removeView(setTabIndicator);
            if (setSpacer1.getParent() != null) ((android.view.ViewGroup)setSpacer1.getParent()).removeView(setSpacer1);
            if (setSpacer2.getParent() != null) ((android.view.ViewGroup)setSpacer2.getParent()).removeView(setSpacer2);

            if (tabIndex == 0) {
                generalTabButton.setTextColor(getColorInt("primary")); generalTabButton.setTypeface(null, Typeface.BOLD);
                callerIdTabButton.setTextColor(getColorInt("on-surface-variant")); callerIdTabButton.setTypeface(null, Typeface.NORMAL);
                filterTabButton.setTextColor(getColorInt("on-surface-variant")); filterTabButton.setTypeface(null, Typeface.NORMAL);
                setIndicatorContainer.addView(setTabIndicator); setIndicatorContainer.addView(setSpacer1); setIndicatorContainer.addView(setSpacer2);
            } else if (tabIndex == 1) {
                generalTabButton.setTextColor(getColorInt("on-surface-variant")); generalTabButton.setTypeface(null, Typeface.NORMAL);
                callerIdTabButton.setTextColor(getColorInt("primary")); callerIdTabButton.setTypeface(null, Typeface.BOLD);
                filterTabButton.setTextColor(getColorInt("on-surface-variant")); filterTabButton.setTypeface(null, Typeface.NORMAL);
                setIndicatorContainer.addView(setSpacer1); setIndicatorContainer.addView(setTabIndicator); setIndicatorContainer.addView(setSpacer2);
            } else if (tabIndex == 2) {
                generalTabButton.setTextColor(getColorInt("on-surface-variant")); generalTabButton.setTypeface(null, Typeface.NORMAL);
                callerIdTabButton.setTextColor(getColorInt("on-surface-variant")); callerIdTabButton.setTypeface(null, Typeface.NORMAL);
                filterTabButton.setTextColor(getColorInt("primary")); filterTabButton.setTypeface(null, Typeface.BOLD);
                setIndicatorContainer.addView(setSpacer1); setIndicatorContainer.addView(setSpacer2); setIndicatorContainer.addView(setTabIndicator);
            }
        }

        generalTabButton.setOnClickListener(new View.OnClickListener() { onClick(View v) { switchToTab(0); } });
        callerIdTabButton.setOnClickListener(new View.OnClickListener() { onClick(View v) { switchToTab(1); } });
        filterTabButton.setOnClickListener(new View.OnClickListener() { onClick(View v) { switchToTab(2); } });

        // === GENERAL TAB ===
        updateCheckbox = createThemedCheckbox(activity, "TC_update_check", false);
        generalTab.addView(createSettingItem(activity, "Auto-check for updates", updateCheckbox));
        
        debugCheckbox = createThemedCheckbox(activity, "TC_debug_enabled", false);
        generalTab.addView(createSettingItem(activity, "Enable debug logging", debugCheckbox));
        
        sdkStr = tasker.getVariable("SDK");
        sdk = sdkStr != null ? Integer.parseInt(sdkStr) : 30;
        themeOptions = sdk >= 31 
            ? new String[]{"Material You", "Auto Dark Light", "Dark", "Light", "Custom Color"}
            : new String[]{"Auto Dark Light", "Dark", "Light", "Custom Color"};
        generalTab.addView(createSettingPickerButton(activity, "Theme", "TC_theme", themeOptions, "Auto Dark Light", dialog, onThemeChanged));

        dbPathContainer = new LinearLayout(activity);
        dbPathContainer.setOrientation(LinearLayout.VERTICAL);
        dbPathContainer.setPadding(u.dpToPx(16), u.dpToPx(12), u.dpToPx(16), u.dpToPx(12));
        dbPathContainer.setBackground(createCardBackground(getThemeColor("surface"), 16));
        dbPathParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        dbPathParams.setMargins(u.dpToPx(8), u.dpToPx(8), u.dpToPx(8), u.dpToPx(8));
        dbPathContainer.setLayoutParams(dbPathParams);
        
        dbLabelContainer = new LinearLayout(activity);
        dbLabelContainer.setOrientation(LinearLayout.HORIZONTAL);
        dbLabel = new TextView(activity);
        dbLabel.setText("Database Path:");
        dbLabel.setTextColor(getColorInt("on-surface"));
        dbLabel.setTextSize(16);
        dbLabelParams = new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0f);
        dbLabel.setLayoutParams(dbLabelParams);
        
        changePathBtn = createThemedSettingsButton(activity, "Change Path");
        changePathBtn.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                /* Run on a background thread so blockingGet() doesn't freeze the UI */
                new Thread(new Runnable() {
                    run() {
                        try {
                            intent = new android.content.Intent(android.content.Intent.ACTION_OPEN_DOCUMENT_TREE);
                            resultIntent = tasker.getWithActivityForResult(intent).blockingGet();
                            
                            if (resultIntent != null && resultIntent.getData() != null) {
                                uri = resultIntent.getData();
                                realDir = tasker.convertToRealFilePath(uri);
                                
                                if (realDir == null || realDir.isEmpty()) {
                                    tasker.showToast("Could not resolve real path. Try selecting a standard internal folder.");
                                    return;
                                }
                                
                                oldPath = tasker.getVariable("TC_dbpath");
                                newPath = realDir + "/Truecaller.db";
                                
                                if (oldPath != null && !oldPath.equals(newPath)) {
                                    oldFile = new java.io.File(oldPath);
                                    if (oldFile.exists()) {
                                        in = new java.io.FileInputStream(oldFile);
                                        out = new java.io.FileOutputStream(newPath);
                                        buf = new byte[1024];
                                        len = 0;
                                        while ((len = in.read(buf)) > 0) {
                                            out.write(buf, 0, len);
                                        }
                                        in.close();
                                        out.close();
                                        oldFile.delete();
                                    }
                                }
                                
                                tasker.setVariable("TC_dbpath", newPath);
                                tasker.showToast("Database path updated successfully");
                                
                                /* Update the UI element safely on the main thread */
                                mainHandler.post(new Runnable() {
                                    run() {
                                        d.reloadDb();
                                        if (dbPathText != null) {
                                            dbPathText.setText(newPath);
                                        }
                                        /* This forces the underlying call log list to rebuild and fetch fresh data */
                                        if (onThemeChanged != null) {
                                            onThemeChanged.run();
                                        }
                                    }
                                });
                            }
                        } catch (Exception e) {
                            tasker.showToast("Error moving DB: " + e.getMessage());
                        }
                    }
                }).start();
            }
        });
        dbLabelContainer.addView(dbLabel);
        dbLabelContainer.addView(changePathBtn);
        
        dbPathText = new android.widget.EditText(activity);
        dbPathText.setText(tasker.getVariable("TC_dbpath"));
        dbPathText.setEnabled(false);
        dbPathText.setTextColor(getColorInt("on-surface-variant"));
        dbPathText.setPadding(u.dpToPx(8), u.dpToPx(8), u.dpToPx(8), u.dpToPx(8));
        dbPathText.setBackgroundColor(getColorInt("surface-variant"));
        dbTextParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        dbTextParams.topMargin = u.dpToPx(12);
        dbPathText.setLayoutParams(dbTextParams);
        
        dbPathContainer.addView(dbLabelContainer);
        dbPathContainer.addView(dbPathText);
        generalTab.addView(dbPathContainer);
        
        actionsContainer = new LinearLayout(activity);
        actionsContainer.setOrientation(LinearLayout.VERTICAL);
        actionsContainer.setPadding(u.dpToPx(16), u.dpToPx(12), u.dpToPx(16), u.dpToPx(12));
        actionsContainer.setBackground(createCardBackground(getThemeColor("surface"), 16));
        actionsParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        actionsParams.setMargins(u.dpToPx(8), u.dpToPx(8), u.dpToPx(8), u.dpToPx(8));
        actionsContainer.setLayoutParams(actionsParams);
        
        updatesBtn = createThemedSettingsButton(activity, "Check for updates");
        updatesBtn.setLayoutParams(new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT));
        updatesBtn.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                tasker.callTask("Truecaller - Update Database", new java.util.HashMap());
            }
        });
        actionsContainer.addView(updatesBtn);
        
        permissionsBtn = createThemedSettingsButton(activity, "Check permissions");
        btnMargins = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        btnMargins.setMargins(0, u.dpToPx(8), 0, 0);
        permissionsBtn.setLayoutParams(btnMargins);
        permissionsBtn.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                taskVars = new java.util.HashMap();
                taskVars.put("par1", "Check Permissions");
                tasker.callTask("Truecaller - Settings", taskVars);
            }
        });
        actionsContainer.addView(permissionsBtn);
        
        nameBtn = createThemedSettingsButton(activity, "Update Name");
        btnMargins2 = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        btnMargins2.setMargins(0, u.dpToPx(8), 0, 0);
        nameBtn.setLayoutParams(btnMargins2);
        nameBtn.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                taskVars = new java.util.HashMap();
                taskVars.put("par1", "Update Name");
                tasker.callTask("Truecaller - Settings", taskVars);
                dialog.dismiss();
            }
        });
        actionsContainer.addView(nameBtn);
        
        resetBtn = createThemedSettingsButton(activity, "Reset");
        btnMargins3 = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        btnMargins3.setMargins(0, u.dpToPx(8), 0, 0);
        resetBtn.setLayoutParams(btnMargins3);
        resetBtn.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                confirmAction = new Runnable() {
                    run() {
                        taskVars = new java.util.HashMap();
                        taskVars.put("par1", "Reset");
                        tasker.callTask("Truecaller - Settings", taskVars);
                        dialog.dismiss();
                    }
                };
                showConfirmDialog(activity, "Confirmation", "Reset Settings?", "Yes", confirmAction);
            }
        });
        actionsContainer.addView(resetBtn);
        
        deleteIdBtn = createThemedSettingsButton(activity, "Delete installationid");
        btnMargins4 = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        btnMargins4.setMargins(0, u.dpToPx(8), 0, 0);
        deleteIdBtn.setLayoutParams(btnMargins4);
        deleteIdBtn.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                confirmAction = new Runnable() {
                    run() {
                        taskVars = new java.util.HashMap();
                        taskVars.put("par1", "Delete Truecaller installationId");
                        tasker.callTask("Truecaller - Settings", taskVars);
                        dialog.dismiss();
                    }
                };
                showConfirmDialog(activity, "Confirmation", "Delete InstallationId?", "Yes", confirmAction);
            }
        });
        actionsContainer.addView(deleteIdBtn);
        
        deleteAccountBtn = createThemedSettingsButton(activity, "Delete Account");
        btnMargins5 = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        btnMargins5.setMargins(0, u.dpToPx(8), 0, 0);
        deleteAccountBtn.setLayoutParams(btnMargins5);
        deleteAccountBtn.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                confirmAction = new Runnable() {
                    run() {
                        taskVars = new java.util.HashMap();
                        taskVars.put("par1", "Delete Truecaller Account");
                        tasker.callTask("Truecaller - Settings", taskVars);
                        dialog.dismiss();
                    }
                };
                showConfirmDialog(activity, "Confirmation", "Delete Account?", "Yes", confirmAction);
            }
        });
        actionsContainer.addView(deleteAccountBtn);
        generalTab.addView(actionsContainer);
        
        // === CALLER ID TAB ===
        callerIdTab.addView(createSettingItem(activity, "Enable Caller ID", createThemedCheckbox(activity, "TC_enable_caller_id", false)));
        callerIdDisplayOptions = new String[]{"Notification", "Overlay"};
        callerIdTab.addView(createSettingPickerButton(activity, "Display Type", "TC_caller_id_display_type", callerIdDisplayOptions, "Notification", dialog, null));
        callerIdTab.addView(createSettingItem(activity, "Enable For Device Contacts", createThemedCheckbox(activity, "TC_enable_device_contacts", false)));
        callerIdTab.addView(createSettingItem(activity, "Enable For Outgoing Calls", createThemedCheckbox(activity, "TC_enable_for_outgoing_calls", false)));
        callerIdTab.addView(createSettingItem(activity, "Missed Call Notification", createThemedCheckbox(activity, "TC_missed_call_notification", false)));
        callerIdTab.addView(createSettingItem(activity, "Caller ID for SMS", createThemedCheckbox(activity, "TC_enable_for_sms", false)));
        callerIdTab.addView(createSettingItem(activity, "WhatsApp Calls", createThemedCheckbox(activity, "TC_enable_for_whatsapp_calls", false)));
        callerIdTab.addView(createSettingItem(activity, "WhatsApp Messages", createThemedCheckbox(activity, "TC_enable_for_whatsapp_msgs", false)));
        callerIdTab.addView(createSettingItem(activity, "Monitor Clipboard", createThemedCheckbox(activity, "TC_monitor_clipboard", false)));
        callerIdTab.addView(createSettingItem(activity, "Enable Share Trigger", createThemedCheckbox(activity, "TC_share_trigger", false)));
        
        // === FILTER TAB ===
        blockMethodOptions = new String[]{"Reject", "Silent", "Pick & hang"};
        filterTab.addView(createSettingPickerButton(activity, "Call Block Method", "TC_call_block_method", blockMethodOptions, "Reject", dialog, null));
      
        filterTab.addView(createSettingItemWithDescription(
            activity,
            "Block All Calls",
            "Blocks every incoming call regardless of number.",
            createThemedCheckbox(activity, "TC_block_all_calls", false)
        ));
      
        filterTab.addView(createSettingItemWithDescription(
            activity,
            "Block Unsaved Numbers",
            "Blocks calls from numbers not saved in your contacts.",
            createThemedCheckbox(activity, "TC_block_unsaved_numbers", false)
        ));
      
        filterTab.addView(createSettingItemWithDescription(
            activity,
            "Block Top Spam Calls",
            "Blocks numbers flagged as Top Spammer.",
            createThemedCheckbox(activity, "TC_spam_calls_block_top_spammers", false)
        ));
      
        filterTab.addView(createSettingItemWithDescription(
            activity,
            "Block Additional Spam Calls",
            "Blocks numbers flagged as Spammer.",
            createThemedCheckbox(activity, "TC_spam_calls_block_additional", false)
        ));
      
        filterTab.addView(createSettingItemWithDescription(
            activity,
            "Early Spam Calls Detection",
            "Blocks numbers flagged as Likely Sales, Likely Spam, Telemarketer, Potential Fraud.",
            createThemedCheckbox(activity, "TC_spam_calls_early_detection", false)
        ));
      
        filterTab.addView(createSettingItemWithDescription(
            activity,
            "Block Private Calls",
            "Blocks calls from hidden/private numbers.",
            createThemedCheckbox(activity, "TC_private_calls_block", false)
        ));
        
        /* User filters button */
        userFiltersContainer = new LinearLayout(activity);
        userFiltersContainer.setOrientation(LinearLayout.HORIZONTAL);
        userFiltersContainer.setGravity(Gravity.CENTER_VERTICAL);
        userFiltersContainer.setWeightSum(1.0f);
        userFiltersContainer.setPadding(u.dpToPx(16), u.dpToPx(12), u.dpToPx(16), u.dpToPx(12));
        userFiltersContainer.setBackground(createCardBackground(getColorString("surface"), 16));
        userFiltersParams = new LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        );
        userFiltersParams.setMargins(u.dpToPx(8), u.dpToPx(8), u.dpToPx(8), u.dpToPx(8));
        userFiltersContainer.setLayoutParams(userFiltersParams);
        
        userFiltersCheckbox = createThemedCheckbox(activity, "TC_user_filters", false);
        
        userFiltersBtn = createThemedSettingsButton(activity, "User Filters");
        userFiltersBtn.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                showUserFiltersDialog(activity, null, null, null, null);
            }
        });
        userFiltersBtnParams = new LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        );
        userFiltersBtn.setLayoutParams(userFiltersBtnParams);
        
        /* Add spacer to push checkbox to the right */
        spacerView = new View(activity);
        spacerParams = new LinearLayout.LayoutParams(
            0,
            LinearLayout.LayoutParams.WRAP_CONTENT,
            1.0f
