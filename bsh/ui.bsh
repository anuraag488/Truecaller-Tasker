        typeDisplay.setTextSize(TypedValue.COMPLEX_UNIT_SP, 14);
        typeDisplay.setTextColor(getColorInt("on-surface"));
        typeDisplay.setPadding(u.dpToPx(12), u.dpToPx(12), u.dpToPx(12), u.dpToPx(12));
