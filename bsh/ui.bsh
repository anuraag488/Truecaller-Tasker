    showConfirmDialog(activity, title, message, positiveText, onConfirm) {
        dialog = new android.app.Dialog(activity);
        dialog.requestWindowFeature(1);
        dialog.getWindow().setBackgroundDrawable(new ColorDrawable(Color.TRANSPARENT));

        dialogLayout = new LinearLayout(activity);
        dialogLayout.setOrientation(LinearLayout.VERTICAL);
        dialogLayout.setPadding(u.dpToPx(24), u.dpToPx(24), u.dpToPx(24), u.dpToPx(16));
        
        dialogBg = createCardBackground(getThemeColor("surface"), 16);
        dialogLayout.setBackground(dialogBg);

        titleText = new TextView(activity);
        titleText.setText(title);
        titleText.setTextSize(TypedValue.COMPLEX_UNIT_SP, 20);
        titleText.setTypeface(null, Typeface.BOLD);
        titleText.setTextColor(getColorInt("on-surface"));
        dialogLayout.addView(titleText);

        if (message != null && !message.isEmpty()) {
            messageText = new TextView(activity);
            messageText.setText(message);
            messageText.setTextSize(TypedValue.COMPLEX_UNIT_SP, 16);
            messageText.setTextColor(getColorInt("on-surface-variant"));
            
            messageParams = new LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT, 
                LinearLayout.LayoutParams.WRAP_CONTENT
            );
            messageParams.topMargin = u.dpToPx(8);
            messageParams.bottomMargin = u.dpToPx(24);
            messageText.setLayoutParams(messageParams);
            dialogLayout.addView(messageText);
        } else {
            titleParams = titleText.getLayoutParams();
            if (titleParams == null) {
                titleParams = new LinearLayout.LayoutParams(
                    LinearLayout.LayoutParams.MATCH_PARENT,
                    LinearLayout.LayoutParams.WRAP_CONTENT
                );
                titleText.setLayoutParams(titleParams);
            }
            titleParams.bottomMargin = u.dpToPx(24);
        }

        buttonContainer = new LinearLayout(activity);
        buttonContainer.setOrientation(LinearLayout.HORIZONTAL);
        buttonContainer.setGravity(Gravity.END);
        
        cancelBtn = new TextView(activity);
        cancelBtn.setText("CANCEL");
        cancelBtn.setTextColor(getColorInt("primary"));
        cancelBtn.setTypeface(null, Typeface.BOLD);
        cancelBtn.setPadding(u.dpToPx(12), u.dpToPx(8), u.dpToPx(12), u.dpToPx(8));
        cancelBtn.setOnClickListener(new View.OnClickListener() {
            onClick(v) {
                dialog.dismiss();
            }
        });
        buttonContainer.addView(cancelBtn);

        confirmBtn = new TextView(activity);
        confirmBtn.setText(positiveText != null ? positiveText : "OK");
        confirmBtn.setTextColor(getColorInt("error"));
        confirmBtn.setTypeface(null, Typeface.BOLD);
        confirmBtn.setPadding(u.dpToPx(12), u.dpToPx(8), u.dpToPx(12), u.dpToPx(8));
        
        confirmBtn.setOnClickListener(new View.OnClickListener() {
            onClick(v) {
                dialog.dismiss();
                if (onConfirm != null) {
                    onConfirm.run();
                }
            }
        });
        buttonContainer.addView(confirmBtn);
        dialogLayout.addView(buttonContainer);
        dialog.setContentView(dialogLayout);
        
        windowParams = dialog.getWindow().getAttributes();
        displayMetrics = activity.getResources().getDisplayMetrics();
        windowParams.width = Math.round(displayMetrics.widthPixels * 0.9f);
        dialog.getWindow().setAttributes(windowParams);
        dialog.show();
    }

    createIconButton(ctx, drawableName, colorHex) {
        btn = new android.widget.Button(ctx);
        btn.setBackground(null);
        btn.setPadding(u.dpToPx(8), u.dpToPx(8), u.dpToPx(8), u.dpToPx(8));
        btn.setMinimumWidth(0);
        btn.setMinWidth(0);
        icon = getDrawable(ctx, drawableName);
        if (icon != null) {
            icon.setTint(Color.parseColor(colorHex));
            btn.setCompoundDrawablesWithIntrinsicBounds(icon, null, null, null);
        }
        return btn;
    }

    createToggleSwitch(ctx, checked) {
        checkBox = new android.widget.CheckBox(ctx);
        checkBox.setChecked(checked);
        checkBox.setButtonDrawable(null);
        iconName = checked ? "mw_toggle_check_box" : "mw_toggle_check_box_outline_blank";
        icon = getDrawable(ctx, iconName);
        if (icon != null) {
            icon.setTint(Color.parseColor(getThemeColor("primary")));
            checkBox.setCompoundDrawablesWithIntrinsicBounds(icon, null, null, null);
        }
        checkBox.setText("");
        checkBox.setPadding(0, 0, 0, 0);
        checkBoxParams = new LinearLayout.LayoutParams(u.dpToPx(24), u.dpToPx(24));
        checkBox.setLayoutParams(checkBoxParams);
        return checkBox;
    }

    createStyledInput(ctx, hint) {
        input = new android.widget.EditText(ctx);
        input.setHint(hint);
        input.setSingleLine(true);
        input.setTextSize(TypedValue.COMPLEX_UNIT_SP, 14);
        input.setTextColor(getColorInt("on-surface"));
        input.setHintTextColor(getColorInt("on-surface-variant"));
        inputBg = new GradientDrawable();
        inputBg.setColor(getColorInt("surface"));
        inputBg.setCornerRadius(u.dpToPx(16));
        inputBg.setStroke(u.dpToPx(1), getColorInt("outline-variant"));
        input.setBackground(inputBg);
        input.setPadding(u.dpToPx(12), u.dpToPx(12), u.dpToPx(12), u.dpToPx(12));
        return input;
    }

    getMatchType(pattern) {
        if (pattern.startsWith("*") && pattern.endsWith("*")) return "contains";
        if (pattern.startsWith("*")) return "ends with";
        if (pattern.endsWith("*")) return "starts with";
        return "matches";
    }

