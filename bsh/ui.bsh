        fieldLabel = new TextView(activity);
        fieldLabel.setText("Filter by:");
        fieldLabel.setTextSize(TypedValue.COMPLEX_UNIT_SP, 16);
        fieldLabel.setTypeface(null, Typeface.BOLD);
        fieldLabel.setTextColor(getColorInt("on-background"));
        formLayout.addView(fieldLabel);

        fields = new java.util.ArrayList();
        fields.add("number");
        fields.add("name");
        
        parsedDetails = (Object[]) state.get("details");
        if (parsedDetails != null && parsedDetails[1] != null && !((String)parsedDetails[1]).equals("<null>")) {
            try {
                json = new org.json.JSONObject((String)parsedDetails[1]);
                dataArray = json.getJSONArray("data");
                if (dataArray.length() > 0) {
                    dataObj = dataArray.getJSONObject(0);
                    if (dataObj.has("countryCode")) fields.add("country code");
                    if (dataObj.has("dialingCode")) fields.add("dialing code");
                    if (dataObj.has("phones")) {
                        phones = dataObj.getJSONArray("phones");
                        if (phones.length() > 0 && phones.getJSONObject(0).has("carrier")) {
                            fields.add("carrier");
                        }
                    }
                }
            } catch (Exception e) {}
        }
        
        fieldDisplay = new TextView(activity);
        fieldDisplay.setText(field != null ? field : "number");
        fieldDisplay.setTextSize(TypedValue.COMPLEX_UNIT_SP, 14);
        fieldDisplay.setTextColor(getColorInt("on-surface"));
        fieldDisplay.setPadding(u.dpToPx(12), u.dpToPx(12), u.dpToPx(12), u.dpToPx(12));
        fieldDisplay.setBackground(displayBg);
        if (dropdownIcon != null) {
            fieldDisplay.setCompoundDrawablesWithIntrinsicBounds(null, null, dropdownIcon, null);
            fieldDisplay.setCompoundDrawablePadding(u.dpToPx(8));
        }

        valueInput = createStyledInput(activity, "Enter value");

        fieldDisplay.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                builder = new android.app.AlertDialog.Builder(activity);
                views = new TextView[fields.size()];
                container = new LinearLayout(activity);
                container.setOrientation(LinearLayout.VERTICAL);
                container.setBackgroundColor(getColorInt("surface"));
                dialogRef = new Object[1];
                for (int i = 0; i < fields.size(); i++) {
                    tv = new TextView(activity);
                    tv.setText((String) fields.get(i));
                    tv.setPadding(u.dpToPx(16), u.dpToPx(16), u.dpToPx(16), u.dpToPx(16));
                    tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 14);
                    tv.setTextColor(getColorInt("on-surface"));
                    tv.setBackgroundColor(getColorInt("surface"));
                    views[i] = tv;
                    container.addView(tv);
                    capturedText = (String) fields.get(i);
                    tv.setOnClickListener(new View.OnClickListener() {
                        onClick(View v2) {
                            fieldDisplay.setText(capturedText);
                            filterNumber = (String) state.get("filterNumber");
                            filterName = (String) state.get("filterName");
                            parsedDetails = (Object[]) state.get("details");
                            
                            if (capturedText.equals("number") && filterNumber != null && !filterNumber.isEmpty()) {
                                valueInput.setText(filterNumber);
                            } else if (capturedText.equals("name") && filterName != null && !filterName.isEmpty()) {
                                valueInput.setText(filterName);
                            } else if (parsedDetails != null) {
                                try {
                                    json = new org.json.JSONObject((String)parsedDetails[1]);
                                    dataArray = json.getJSONArray("data");
                                    if (dataArray.length() > 0) {
                                        dataObj = dataArray.getJSONObject(0);
                                        if (capturedText.equals("country code") && dataObj.has("countryCode")) {
                                            valueInput.setText(dataObj.getString("countryCode"));
                                        } else if (capturedText.equals("dialing code") && dataObj.has("dialingCode")) {
                                            valueInput.setText(dataObj.getString("dialingCode"));
                                        } else if (capturedText.equals("carrier") && dataObj.has("phones")) {
                                            phones = dataObj.getJSONArray("phones");
                                            if (phones.length() > 0 && phones.getJSONObject(0).has("carrier")) {
                                                valueInput.setText(phones.getJSONObject(0).getString("carrier"));
                                            }
                                        }
                                    }
                                } catch (Exception e) {}
                            }
                            ((android.app.AlertDialog)dialogRef[0]).dismiss();
                        }
                    });
                }
                builder.setView(container);
                dAlert = builder.create();
                dialogRef[0] = dAlert;
                dAlert.getWindow().setBackgroundDrawable(new android.graphics.drawable.ColorDrawable(getColorInt("surface")));
                dAlert.show();
            }
        });
        fieldSpinnerParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        fieldSpinnerParams.topMargin = u.dpToPx(8);
        fieldSpinnerParams.bottomMargin = u.dpToPx(16);
        fieldDisplay.setLayoutParams(fieldSpinnerParams);
        formLayout.addView(fieldDisplay);

        matchLabel = new TextView(activity);
        matchLabel.setText("Match type:");
        matchLabel.setTextSize(TypedValue.COMPLEX_UNIT_SP, 16);
        matchLabel.setTypeface(null, Typeface.BOLD);
        matchLabel.setTextColor(getColorInt("on-background"));
        formLayout.addView(matchLabel);
        
        matches = new java.util.ArrayList();
        matches.add("matches");
        matches.add("contains");
        matches.add("starts with");
        matches.add("ends with");
        
        matchDisplay = new TextView(activity);
        matchDisplay.setText(value != null ? getMatchType(value) : "matches");
        matchDisplay.setTextSize(TypedValue.COMPLEX_UNIT_SP, 14);
        matchDisplay.setTextColor(getColorInt("on-surface"));
        matchDisplay.setPadding(u.dpToPx(12), u.dpToPx(12), u.dpToPx(12), u.dpToPx(12));
        matchDisplay.setBackground(displayBg);
        if (dropdownIcon != null) {
