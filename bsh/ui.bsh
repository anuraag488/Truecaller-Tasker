ui() {
    u = util();
    d = data();

    LONG_PRESS_DELAY = 500;
    mainHandler = new android.os.Handler(android.os.Looper.getMainLooper());
    executorService = Executors.newCachedThreadPool();
    
    themeColors = new HashMap();
    colorCache = new HashMap();

    getColorInt(key) {
        cached = colorCache.get(key);
        if (cached != null) return cached;
        colorStr = themeColors.get(key);
        colorInt = Color.parseColor(colorStr != null ? colorStr : "#000000");
        colorCache.put(key, colorInt);
        return colorInt;
    }
    
    getColorString(key) {
        colorStr = themeColors.get(key);
        return colorStr != null ? colorStr : "#000000";
    }

    getThemeColor(key) {
        color = themeColors.get(key);
        return color != null ? color : "#000000";
    }

    imageLoader = null;
    disposableMap = new WeakHashMap();
    
    setupCoilImageLoader() {
        try {
            cacheDir = new File(context.getExternalCacheDir(), "image_cache");
            if (!cacheDir.exists()) cacheDir.mkdirs();
            try {
                diskCache = new DiskCache.Builder()
                    .directory(cacheDir)
                    .maxSizeBytes(200L * 1024L * 1024L)
                    .build();
            } catch (Exception e) {
                u.logToFile("DiskCache locked, falling back to memory only: " + e.getMessage());
                diskCache = null;
            }
            
            memoryCache = new MemoryCache.Builder(context)
                .maxSizePercent(0.25)
                .build();
            
            builder = new ImageLoader.Builder(context).memoryCache(memoryCache).allowHardware(false);
            if (diskCache != null) builder.diskCache(diskCache);
            imageLoader = builder.build();
        } catch (Exception e) {
            u.logToFile("Error setting up Coil: " + e.getMessage());
        }
    }
    
    setupCoilImageLoader();
    
    onSettingsClosed = null;

    cancelImageLoad(imageView) {
        existingDisposable = disposableMap.get(imageView);
        if (existingDisposable != null) {
            try { existingDisposable.dispose(); } catch (Exception e) {}
            disposableMap.remove(imageView);
        }
    }

    loadIconAsync(iconUrl, iconView) {
        if (!u.isValidString(iconUrl)) return;
        cancelImageLoad(iconView);
        request = new ImageRequest.Builder(context)
            .data(iconUrl)
            .target(iconView)
            .allowHardware(false)
            .build();
        disposable = imageLoader.enqueue(request);
        disposableMap.put(iconView, disposable);
    }

    createInitialBitmap(name, sizeDp) {
        size = u.dpToPx(sizeDp);
        bitmap = Bitmap.createBitmap(size, size, Bitmap.Config.ARGB_8888);
        bitmap.setHasAlpha(true);
        canvas = new Canvas(bitmap);
        paint = new Paint();
        paint.setAntiAlias(true);
        paint.setColor(getColorInt("primary"));
        canvas.drawCircle(size / 2, size / 2, size / 2, paint);
        
        initial = "?";
        if (u.isValidString(name)) {
            for (int i = 0; i < name.length(); i++) {
                c = name.charAt(i);
                if (Character.isLetter(c)) {
                    initial = String.valueOf(c).toUpperCase();
                    break;
                }
            }
        }
        paint.setColor(getColorInt("on-primary"));
        paint.setTextSize(u.dpToPx(sizeDp / 2));
        paint.setTypeface(Typeface.DEFAULT_BOLD);
        paint.setTextAlign(Paint.Align.CENTER);
        bounds = new android.graphics.Rect();
        paint.getTextBounds(initial, 0, initial.length(), bounds);
        canvas.drawText(initial, size / 2, size / 2 + bounds.height() / 2, paint);
        return bitmap;
    }

    loadImageAsync(image, avatarView, name, sizeDp) {
        cancelImageLoad(avatarView);
        initialBitmap = createInitialBitmap(name, sizeDp);
        initialDrawable = new BitmapDrawable(context.getResources(), initialBitmap);
        request = new ImageRequest.Builder(context)
            .data(image)
            .transformations(new CircleCropTransformation())
            .target(avatarView)
            .placeholder(initialDrawable) 
            .error(initialDrawable)       
            .allowHardware(false)
            .build();
        disposable = imageLoader.enqueue(request);
        disposableMap.put(avatarView, disposable);
    }

    createCardBackground(bgColor, radiusDp) {
        bg = new GradientDrawable();
        bg.setColor(Color.parseColor(bgColor));
        bg.setCornerRadius(u.dpToPx(radiusDp));
        bg.setStroke(u.dpToPx(1), getColorInt("outline-variant"));
        return bg;
    }

    getDrawable(activity, drawableName) {
        resourceId = context.getResources().getIdentifier(drawableName, "drawable", context.getPackageName());
        if (resourceId != 0) {
            return context.getResources().getDrawable(resourceId);
        }
        return null;
    }

    setupLongPressHandler(view, final Runnable onLongPress) {
        final boolean[] state = new boolean[]{false};
        final Runnable wrapper = new Runnable() {
            run() {
                state[0] = true;
                onLongPress.run();
            }
        };
        view.setOnTouchListener(new View.OnTouchListener() {
            onTouch(v, event) {
                action = event.getAction();
                if (action == MotionEvent.ACTION_DOWN) {
                    state[0] = false;
                    mainHandler.postDelayed(wrapper, LONG_PRESS_DELAY);
                    return true;
                } else if (action == MotionEvent.ACTION_UP || action == MotionEvent.ACTION_CANCEL) {
                    mainHandler.removeCallbacks(wrapper);
                    if (action == MotionEvent.ACTION_UP && !state[0]) {
                        v.performClick();
                    }
                    return true;
                }
                return false;
            }
        });
    }

    showContactViaDialog(activity, number) {
        e164Number = u.convertToE164(number);
        contactsUri = android.net.Uri.parse("content://com.android.contacts/data");
        apps = new java.util.ArrayList();

        cursor1 = null;
        try {
            projection1 = new String[]{"contact_id"};
            cursor1 = context.getContentResolver().query(contactsUri, projection1, "data4 = ?", new String[]{e164Number}, null);

            while (cursor1 != null && cursor1.moveToNext()) {
                contactId = cursor1.getString(0);
                cursor = null;
                try {
                    projection = new String[]{"_id", "account_type", "mimetype", "data3"};
                    cursor = context.getContentResolver().query(contactsUri, projection, "contact_id = ?", new String[]{contactId}, null);

                    while (cursor != null && cursor.moveToNext()) {
                        dataId = cursor.getString(0);
                        accountType = cursor.getString(1);
                        mimetype = cursor.getString(2);
                        label = cursor.getString(3);

                        intent = new android.content.Intent(android.content.Intent.ACTION_VIEW);
                        intent.setDataAndType(android.net.Uri.parse("content://com.android.contacts/data/" + dataId), mimetype);
                        intent.setPackage(accountType);
                        intent.addFlags(android.content.Intent.FLAG_ACTIVITY_NEW_TASK);

                        pm = context.getPackageManager();
                        resolveInfos = pm.queryIntentActivities(intent, 131072);
                        if (resolveInfos == null || resolveInfos.size() == 0) continue;

                        try {
                            appInfo = pm.getApplicationInfo(accountType, 0);
                            appName = pm.getApplicationLabel(appInfo).toString();
                            appIcon = pm.getApplicationIcon(accountType);

                            appData = new Object[3];
                            appData[0] = appIcon;
                            appData[1] = (label != null ? label : appName);
                            appData[2] = intent;
                            apps.add(appData);
                        } catch (Exception e) {}
                    }
                } finally {
                    u.closeQuietly(cursor);
                }
            }
        } catch (Exception e) {
            u.logToFile("Error querying contact apps: " + e.getMessage());
        } finally {
            u.closeQuietly(cursor1);
        }

        if (apps.isEmpty()) {
            tasker.showToast("No apps found for this contact");
            return;
        }

        dialog = new android.app.Dialog(activity);
        dialog.requestWindowFeature(1);
        dialog.getWindow().setBackgroundDrawable(new ColorDrawable(Color.TRANSPARENT));

        mainLayout = new LinearLayout(activity);
        mainLayout.setOrientation(LinearLayout.VERTICAL);
        mainBg = createCardBackground(getThemeColor("surface"), 16);
        mainLayout.setBackground(mainBg);
        mainLayout.setPadding(u.dpToPx(20), u.dpToPx(20), u.dpToPx(20), u.dpToPx(20));

        titleText = new TextView(activity);
        titleText.setText("Contact Via");
        titleText.setTextSize(TypedValue.COMPLEX_UNIT_SP, 20);
        titleText.setTypeface(null, Typeface.BOLD);
        titleText.setTextColor(getColorInt("on-surface"));
        titleText.setGravity(Gravity.CENTER);
        titleParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        titleParams.bottomMargin = u.dpToPx(20);
        titleText.setLayoutParams(titleParams);
        mainLayout.addView(titleText);

        scrollView = new android.widget.ScrollView(activity);
        scrollView.setLayoutParams(new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, 0, 1.0f));

        appsContainer = new LinearLayout(activity);
        appsContainer.setOrientation(LinearLayout.VERTICAL);

        for (int i = 0; i < apps.size(); i++) {
            appData = (Object[]) apps.get(i);
            appIcon = (android.graphics.drawable.Drawable) appData[0];
            appLabel = (String) appData[1];
            appIntent = (android.content.Intent) appData[2];

            appCard = new LinearLayout(activity);
            appCard.setOrientation(LinearLayout.HORIZONTAL);
            appCard.setPadding(u.dpToPx(16), u.dpToPx(16), u.dpToPx(16), u.dpToPx(16));
            appCard.setGravity(Gravity.CENTER_VERTICAL);
            appCardParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
            appCardParams.bottomMargin = u.dpToPx(12);
            appCard.setLayoutParams(appCardParams);
            appCardBg = createCardBackground(getThemeColor("surface-variant"), 12);
            appCard.setBackground(appCardBg);

            iconView = new ImageView(activity);
            iconSize = u.dpToPx(40);
            iconParams = new LinearLayout.LayoutParams(iconSize, iconSize);
            iconParams.rightMargin = u.dpToPx(16);
            iconView.setLayoutParams(iconParams);
            iconView.setImageDrawable(appIcon);
            appCard.addView(iconView);

            labelText = new TextView(activity);
            labelText.setText(appLabel);
            labelText.setTextSize(TypedValue.COMPLEX_UNIT_SP, 16);
            labelText.setTextColor(getColorInt("on-surface"));
            labelText.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0f));
            appCard.addView(labelText);

            finalIntent = appIntent;
            appCard.setOnClickListener(new View.OnClickListener() {
                onClick(View v) {
                    try {
                        context.startActivity(finalIntent);
                        dialog.dismiss();
                    } catch (Exception e) {
                        tasker.showToast("Cannot open app");
                    }
                }
            });

            appsContainer.addView(appCard);
        }

        scrollView.addView(appsContainer);
        mainLayout.addView(scrollView);

        cancelButton = new TextView(activity);
        cancelButton.setText("CANCEL");
        cancelButton.setTextColor(getColorInt("primary"));
        cancelButton.setTypeface(null, Typeface.BOLD);
        cancelButton.setPadding(u.dpToPx(12), u.dpToPx(8), u.dpToPx(12), u.dpToPx(8));
        
        buttonContainer = new LinearLayout(activity);
        buttonContainer.setOrientation(LinearLayout.HORIZONTAL);
        buttonContainer.setGravity(Gravity.END);
        buttonContainerParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        buttonContainerParams.topMargin = u.dpToPx(8);
        buttonContainer.setLayoutParams(buttonContainerParams);
        buttonContainer.addView(cancelButton);
        
        cancelButton.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                dialog.dismiss();
            }
        });
        mainLayout.addView(buttonContainer);

        dialog.setContentView(mainLayout);
        windowParams = dialog.getWindow().getAttributes();
        displayMetrics = activity.getResources().getDisplayMetrics();
        windowParams.width = Math.round(displayMetrics.widthPixels * 0.9f);
        dialog.getWindow().setAttributes(windowParams);
        dialog.show();
    }

    setClip(str) {
        clipboard = context.getSystemService(Context.CLIPBOARD_SERVICE);
        clip = ClipData.newPlainText("phone", str);
        clipboard.setPrimaryClip(clip);
        tasker.showToast("Copied: " + str);
