        if (note != null && !note.isEmpty()) {
            noteText = new TextView(activity);
            noteText.setText(note);
            noteText.setTextSize(TypedValue.COMPLEX_UNIT_SP, 12);
            noteText.setTextColor(getColorInt("on-surface-variant"));
            noteText.setGravity(Gravity.CENTER);
            noteParams = new LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT);
            noteParams.topMargin = u.dpToPx(4);
            noteText.setLayoutParams(noteParams);
            valueLayout.addView(noteText);
        }
        card.addView(valueLayout);
        
        actionsLayout = new LinearLayout(activity);
        actionsLayout.setOrientation(LinearLayout.VERTICAL);
        actionsLayout.setGravity(Gravity.CENTER);
        
        editButton = createIconButton(activity, "mw_editor_mode_edit", getThemeColor("primary"));
        finalType = type;
        finalField = field;
        finalValue2 = value;
        finalNote = note;
        editButton.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                renderUserFiltersEdit(activity, rootLayout, dialog, state, finalType, finalField, finalValue2, finalNote, finalValue2);
            }
        });
        actionsLayout.addView(editButton);
        
        deleteButton = createIconButton(activity, "mw_action_delete_forever", "#C62828");
        finalValueForDelete = value;
        finalCleanValue = cleanValue;
        
        deleteButton.setOnClickListener(new View.OnClickListener() {
            onClick(View v) {
                confirmAction = new Runnable() {
                    run() {
                        d.deleteFilter(finalValueForDelete);
                        tasker.showToast("Filter deleted");
                        refreshRunnable.run();
                    }
                };
                showConfirmDialog(activity, "Delete Filter", "Are you sure you want to delete the filter for: " + finalCleanValue + "?", "DELETE", confirmAction);
            }
        });
        actionsLayout.addView(deleteButton);
        card.addView(actionsLayout);
        return card;
    }

    showPickDialog(activity, rootLayout, dialog, state) {
        contacts = d.loadFilterContacts();
        if (contacts.isEmpty()) {
            tasker.showToast("No contacts in database");
            return;
        }
        
        contactNames = new java.util.ArrayList();
        for (int i = 0; i < contacts.size(); i++) {
            contact = (Object[]) contacts.get(i);
            contactNames.add(contact[0] + "\n" + contact[1]);
        }
        
        items = (String[]) contactNames.toArray(new String[0]);
        builder = new android.app.AlertDialog.Builder(activity);
        builder.setTitle("Select number to filter");
        builder.setItems(items, new android.content.DialogInterface.OnClickListener() {
            onClick(android.content.DialogInterface dlg, int which) {
                selectedContact = (Object[]) contacts.get(which);
                selectedName = (String) selectedContact[0];
                selectedNumber = (String) selectedContact[1];
                selectedJson = (String) selectedContact[2];
                cleanName = selectedName.replace(" ✅", "").replace(" 🔴", "");
                
                detailsForFilter = new Object[6];
                detailsForFilter[0] = cleanName;
                detailsForFilter[1] = selectedJson;
                detailsForFilter[2] = new Integer(0);
                detailsForFilter[3] = Boolean.FALSE;
                detailsForFilter[4] = null;
                detailsForFilter[5] = null;
                
                state.put("filterNumber", selectedNumber);
                state.put("filterName", cleanName);
                state.put("details", detailsForFilter);
                
                renderUserFiltersEdit(activity, rootLayout, dialog, state, "Block", null, null, null, null);
            }
        });
        builder.setNegativeButton("Cancel", null);
        builder.create().show();
    }

    renderUserFiltersEdit(activity, rootLayout, dialog, state, type, field, value, note, oldValue) {
        rootLayout.removeAllViews();
